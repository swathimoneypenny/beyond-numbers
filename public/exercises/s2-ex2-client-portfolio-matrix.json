{
  "schemaVersion": "1.0",
  "id": "s2-ex2-client-portfolio-matrix",
  "session": 2,
  "exercise": 2,
  "title": "Client Portfolio Evaluation",
  "type": "matrix",
  "summary": "Map clients on a value-vs-effort matrix and assign Gold / Silver / Bronze / Fire tiers to guide who to grow, hold, or fire.",
  "interactive": true,
  "brand": {
    "deepPurple": "#574A9E",
    "gold": "#E6B450",
    "teal": "#4ECDC4",
    "gradient": [
      "#667EEA",
      "#764BA2"
    ],
    "font": "Calibri"
  },
  "embed": {
    "format": "html",
    "selfContained": true,
    "markup": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Client Portfolio Evaluation Exercise</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            min-height: 100vh;\n            padding: 20px;\n        }\n        \n        .container {\n            max-width: 1400px;\n            margin: 0 auto;\n            background: white;\n            border-radius: 20px;\n            padding: 40px;\n            box-shadow: 0 20px 60px rgba(0,0,0,0.3);\n        }\n        \n        .header {\n            text-align: center;\n            margin-bottom: 40px;\n        }\n        \n        .header h1 {\n            color: #667eea;\n            font-size: 36px;\n            margin-bottom: 10px;\n        }\n        \n        .header p {\n            color: #718096;\n            font-size: 18px;\n        }\n        \n        .instructions {\n            background: #fef5e7;\n            border: 2px solid #f6e05e;\n            border-radius: 10px;\n            padding: 20px;\n            margin-bottom: 30px;\n        }\n        \n        .instructions h3 {\n            color: #744210;\n            margin-bottom: 10px;\n        }\n        \n        .instructions ol {\n            margin-left: 20px;\n            line-height: 1.8;\n        }\n        \n        /* Client Entry Section */\n        .client-entry {\n            margin-bottom: 40px;\n        }\n        \n        .add-client-btn {\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: white;\n            border: none;\n            padding: 15px 30px;\n            border-radius: 10px;\n            font-size: 16px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            margin-bottom: 20px;\n        }\n        \n        .add-client-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);\n        }\n        \n        .client-table {\n            width: 100%;\n            border-collapse: collapse;\n            margin-bottom: 30px;\n        }\n        \n        .client-table th {\n            background: #667eea;\n            color: white;\n            padding: 12px;\n            text-align: left;\n            font-weight: 600;\n        }\n        \n        .client-table td {\n            padding: 10px;\n            border-bottom: 1px solid #e2e8f0;\n        }\n        \n        .client-table tr:hover {\n            background: #f7fafc;\n        }\n        \n        .client-input {\n            width: 100%;\n            padding: 8px;\n            border: 1px solid #cbd5e0;\n            border-radius: 5px;\n            font-size: 14px;\n        }\n        \n        .score-input {\n            width: 60px;\n            text-align: center;\n        }\n        \n        .remove-btn {\n            background: #fc8181;\n            color: white;\n            border: none;\n            padding: 5px 10px;\n            border-radius: 5px;\n            cursor: pointer;\n            font-size: 12px;\n        }\n        \n        .remove-btn:hover {\n            background: #f56565;\n        }\n        \n        /* Matrix Visualization */\n        .matrix-section {\n            margin-bottom: 40px;\n        }\n        \n        .matrix-container {\n            position: relative;\n            width: 100%;\n            height: 600px;\n            background: #f7fafc;\n            border-radius: 15px;\n            padding: 20px;\n            margin-bottom: 20px;\n        }\n        \n        .matrix-grid {\n            position: relative;\n            width: 100%;\n            height: 100%;\n            border-left: 3px solid #2d3748;\n            border-bottom: 3px solid #2d3748;\n        }\n        \n        .matrix-quadrant {\n            position: absolute;\n            width: 50%;\n            height: 50%;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 20px;\n            overflow: auto;\n        }\n        \n        .q1 {\n            top: 0;\n            right: 0;\n            background: rgba(72, 187, 120, 0.1);\n            border-left: 1px dashed #cbd5e0;\n            border-bottom: 1px dashed #cbd5e0;\n        }\n        \n        .q2 {\n            top: 0;\n            left: 0;\n            background: rgba(246, 224, 94, 0.1);\n            border-right: 1px dashed #cbd5e0;\n            border-bottom: 1px dashed #cbd5e0;\n        }\n        \n        .q3 {\n            bottom: 0;\n            left: 0;\n            background: rgba(252, 129, 129, 0.1);\n            border-right: 1px dashed #cbd5e0;\n            border-top: 1px dashed #cbd5e0;\n        }\n        \n        .q4 {\n            bottom: 0;\n            right: 0;\n            background: rgba(102, 126, 234, 0.1);\n            border-left: 1px dashed #cbd5e0;\n            border-top: 1px dashed #cbd5e0;\n        }\n        \n        .quadrant-label {\n            font-weight: bold;\n            font-size: 18px;\n            margin-bottom: 15px;\n            text-align: center;\n        }\n        \n        .client-dot {\n            position: absolute;\n            width: 40px;\n            height: 40px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: bold;\n            color: white;\n            font-size: 12px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 2px 5px rgba(0,0,0,0.2);\n        }\n        \n        .client-dot:hover {\n            transform: scale(1.2);\n            z-index: 100;\n        }\n        \n        .client-tooltip {\n            position: absolute;\n            background: #2d3748;\n            color: white;\n            padding: 8px 12px;\n            border-radius: 5px;\n            font-size: 12px;\n            white-space: nowrap;\n            display: none;\n            z-index: 1000;\n        }\n        \n        .axis-label {\n            position: absolute;\n            font-weight: bold;\n            color: #2d3748;\n        }\n        \n        .x-axis-label {\n            bottom: -30px;\n            left: 50%;\n            transform: translateX(-50%);\n        }\n        \n        .y-axis-label {\n            left: -80px;\n            top: 50%;\n            transform: translateY(-50%) rotate(-90deg);\n        }\n        \n        /* Analysis Section */\n        .analysis-section {\n            background: #e6f4ff;\n            border-radius: 15px;\n            padding: 30px;\n            margin-bottom: 30px;\n        }\n        \n        .stats-grid {\n            display: grid;\n            grid-template-columns: repeat(4, 1fr);\n            gap: 20px;\n            margin-top: 20px;\n        }\n        \n        .stat-card {\n            background: white;\n            padding: 20px;\n            border-radius: 10px;\n            text-align: center;\n        }\n        \n        .stat-value {\n            font-size: 32px;\n            font-weight: bold;\n            color: #667eea;\n            margin-bottom: 5px;\n        }\n        \n        .stat-label {\n            font-size: 14px;\n            color: #718096;\n        }\n        \n        /* Action Plan */\n        .action-section {\n            background: #f0fff4;\n            border: 2px solid #48bb78;\n            border-radius: 15px;\n            padding: 30px;\n            margin-bottom: 30px;\n        }\n        \n        .action-grid {\n            display: grid;\n            grid-template-columns: repeat(3, 1fr);\n            gap: 20px;\n            margin-top: 20px;\n        }\n        \n        .action-card {\n            background: white;\n            padding: 20px;\n            border-radius: 10px;\n            border: 2px solid #48bb78;\n        }\n        \n        .action-card h4 {\n            color: #22543d;\n            margin-bottom: 15px;\n        }\n        \n        .action-list {\n            list-style: none;\n            padding: 0;\n        }\n        \n        .action-list li {\n            padding: 5px 0;\n            color: #4a5568;\n        }\n        \n        <!-- Buttons -->\n        .control-buttons {\n            display: flex;\n            justify-content: center;\n            gap: 20px;\n            margin: 30px 0;\n            flex-wrap: wrap;\n        }\n        \n        .btn {\n            padding: 15px 30px;\n            border-radius: 10px;\n            font-size: 16px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            border: none;\n        }\n        \n        .analyze-btn {\n            background: linear-gradient(135deg, #48bb78 0%, #68d391 100%);\n            color: white;\n        }\n        \n        .analyze-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 10px 20px rgba(72, 187, 120, 0.3);\n        }\n        \n        .save-btn {\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: white;\n        }\n        \n        .save-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);\n        }\n        \n        .load-btn {\n            background: linear-gradient(135deg, #4ecdc4 0%, #44a8b3 100%);\n            color: white;\n        }\n        \n        .load-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 10px 20px rgba(78, 205, 196, 0.3);\n        }\n        \n        .print-btn {\n            background: linear-gradient(135deg, #805ad5 0%, #9f7aea 100%);\n            color: white;\n        }\n        \n        .print-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 10px 20px rgba(128, 90, 213, 0.3);\n        }\n        \n        .export-btn {\n            background: linear-gradient(135deg, #f6e05e 0%, #faf089 100%);\n            color: #744210;\n        }\n        \n        .export-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 10px 20px rgba(246, 224, 94, 0.3);\n        }\n        \n        .clear-btn {\n            background: linear-gradient(135deg, #fc8181 0%, #feb2b2 100%);\n            color: white;\n        }\n        \n        .clear-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 10px 20px rgba(252, 129, 129, 0.3);\n        }\n        \n        .reset-btn {\n            background: linear-gradient(135deg, #fc8181 0%, #feb2b2 100%);\n            color: white;\n        }\n        \n        .reset-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 10px 20px rgba(252, 129, 129, 0.3);\n        }\n        \n        /* Save notification */\n        .notification {\n            position: fixed;\n            top: 20px;\n            right: 20px;\n            background: #48bb78;\n            color: white;\n            padding: 15px 25px;\n            border-radius: 10px;\n            box-shadow: 0 5px 20px rgba(0,0,0,0.2);\n            display: none;\n            animation: slideIn 0.3s ease-out;\n            z-index: 1001;\n        }\n        \n        @keyframes slideIn {\n            from {\n                transform: translateX(100%);\n                opacity: 0;\n            }\n            to {\n                transform: translateX(0);\n                opacity: 1;\n            }\n        }\n        \n        .notification.show {\n            display: block;\n        }\n        \n        @media print {\n            body {\n                background: white;\n                padding: 10px;\n            }\n            \n            .container {\n                box-shadow: none;\n                padding: 20px;\n                max-width: 100%;\n            }\n            \n            .control-buttons, .add-client-btn, .remove-btn, .instructions {\n                display: none !important;\n            }\n            \n            .header h1 {\n                color: #2d3748 !important;\n                font-size: 24px;\n            }\n            \n            .header p {\n                font-size: 14px;\n            }\n            \n            .client-table {\n                font-size: 11px;\n            }\n            \n            .matrix-container {\n                height: 400px;\n                break-inside: avoid;\n            }\n            \n            .analysis-section, .action-section {\n                break-inside: avoid;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>ðŸŽ¯ Client Portfolio Evaluation Matrix</h1>\n            <p>Identify your ideal advisory clients in 10 minutes</p>\n        </div>\n        \n        <div class=\"instructions\">\n            <h3>ðŸ“‹ Instructions:</h3>\n            <ol>\n                <li><strong>Add Clients:</strong> Enter your top 20 clients (or start with 10)</li>\n                <li><strong>Score Value (1-5):</strong> Revenue potential, growth, referrals, strategic importance</li>\n                <li><strong>Score Effort (1-5):</strong> Time demands, tech resistance, communication needs, deadline stress</li>\n                <li><strong>Analyze:</strong> Click \"Generate Matrix\" to visualize your client portfolio</li>\n                <li><strong>Plan:</strong> Identify 3 clients to transition to advisory services first</li>\n            </ol>\n        </div>\n        \n        <div class=\"client-entry\">\n            <button class=\"add-client-btn\" onclick=\"addClient()\">\n                âž• Add Client\n            </button>\n            \n            <table class=\"client-table\" id=\"clientTable\">\n                <thead>\n                    <tr>\n                        <th width=\"30%\">Client Name</th>\n                        <th width=\"20%\">Industry</th>\n                        <th width=\"15%\">Annual Revenue</th>\n                        <th width=\"10%\">Value Score (1-5)</th>\n                        <th width=\"10%\">Effort Score (1-5)</th>\n                        <th width=\"10%\">Quadrant</th>\n                        <th width=\"5%\">Action</th>\n                    </tr>\n                </thead>\n                <tbody id=\"clientTableBody\">\n                    <!-- Client rows will be added here -->\n                </tbody>\n            </table>\n        </div>\n        \n        <div class=\"control-buttons\">\n            <button class=\"btn analyze-btn\" onclick=\"generateMatrix()\">\n                ðŸ“Š Generate Matrix\n            </button>\n            <button class=\"btn export-btn\" onclick=\"exportData()\">\n                ðŸ“¥ Export Results\n            </button>\n            <button class=\"btn reset-btn\" onclick=\"resetAll()\">\n                ðŸ”„ Reset All\n            </button>\n        </div>\n        \n        <div class=\"matrix-section\" id=\"matrixSection\" style=\"display: none;\">\n            <h2 style=\"text-align: center; color: #2d3748; margin-bottom: 20px;\">\n                Your Client Portfolio Matrix\n            </h2>\n            <div class=\"matrix-container\">\n                <div class=\"matrix-grid\" id=\"matrixGrid\">\n                    <div class=\"matrix-quadrant q1\">\n                        <div class=\"quadrant-label\" style=\"color: #22543d;\">â­ IDEAL<br>High Value + Low Effort</div>\n                        <div id=\"q1Clients\"></div>\n                    </div>\n                    <div class=\"matrix-quadrant q2\">\n                        <div class=\"quadrant-label\" style=\"color: #744210;\">ðŸŽ¯ DEVELOP<br>High Value + High Effort</div>\n                        <div id=\"q2Clients\"></div>\n                    </div>\n                    <div class=\"matrix-quadrant q3\">\n                        <div class=\"quadrant-label\" style=\"color: #742a2a;\">ðŸšª EXIT<br>Low Value + High Effort</div>\n                        <div id=\"q3Clients\"></div>\n                    </div>\n                    <div class=\"matrix-quadrant q4\">\n                        <div class=\"quadrant-label\" style=\"color: #3c366b;\">âš¡ AUTOMATE<br>Low Value + Low Effort</div>\n                        <div id=\"q4Clients\"></div>\n                    </div>\n                    <div class=\"axis-label x-axis-label\">Value to Firm â†’</div>\n                    <div class=\"axis-label y-axis-label\">Effort Required â†’</div>\n                </div>\n            </div>\n            <div class=\"client-tooltip\" id=\"clientTooltip\"></div>\n        </div>\n        \n        <div class=\"analysis-section\" id=\"analysisSection\" style=\"display: none;\">\n            <h2 style=\"text-align: center; color: #2d3748; margin-bottom: 20px;\">\n                Portfolio Analysis\n            </h2>\n            <div class=\"stats-grid\">\n                <div class=\"stat-card\">\n                    <div class=\"stat-value\" id=\"idealCount\">0</div>\n                    <div class=\"stat-label\">Ideal Clients</div>\n                </div>\n                <div class=\"stat-card\">\n                    <div class=\"stat-value\" id=\"developCount\">0</div>\n                    <div class=\"stat-label\">Develop Clients</div>\n                </div>\n                <div class=\"stat-card\">\n                    <div class=\"stat-value\" id=\"exitCount\">0</div>\n                    <div class=\"stat-label\">Exit Candidates</div>\n                </div>\n                <div class=\"stat-card\">\n                    <div class=\"stat-value\" id=\"automateCount\">0</div>\n                    <div class=\"stat-label\">Automate Clients</div>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"action-section\" id=\"actionSection\" style=\"display: none;\">\n            <h2 style=\"text-align: center; color: #22543d; margin-bottom: 20px;\">\n                ðŸš€ Your Action Plan\n            </h2>\n            <div class=\"action-grid\">\n                <div class=\"action-card\">\n                    <h4>Immediate Actions (This Week)</h4>\n                    <ul class=\"action-list\" id=\"immediateActions\">\n                        <!-- Actions will be generated here -->\n                    </ul>\n                </div>\n                <div class=\"action-card\">\n                    <h4>30-Day Priorities</h4>\n                    <ul class=\"action-list\" id=\"thirtyDayActions\">\n                        <!-- Actions will be generated here -->\n                    </ul>\n                </div>\n                <div class=\"action-card\">\n                    <h4>90-Day Goals</h4>\n                    <ul class=\"action-list\" id=\"ninetyDayActions\">\n                        <!-- Actions will be generated here -->\n                    </ul>\n                </div>\n            </div>\n        </div>\n    </div>\n    \n    <script>\n        let clients = [];\n        let clientId = 0;\n        \n        // Sample industries\n        const industries = [\n            'Restaurant', 'Construction', 'Retail', 'Professional Services',\n            'Healthcare', 'Real Estate', 'Manufacturing', 'Technology',\n            'Non-Profit', 'E-commerce', 'Consulting', 'Other'\n        ];\n        \n        function addClient() {\n            clientId++;\n            const tbody = document.getElementById('clientTableBody');\n            const row = document.createElement('tr');\n            row.id = `client-${clientId}`;\n            \n            row.innerHTML = `\n                <td><input type=\"text\" class=\"client-input\" id=\"name-${clientId}\" placeholder=\"Client name\"></td>\n                <td>\n                    <select class=\"client-input\" id=\"industry-${clientId}\">\n                        <option value=\"\">Select industry</option>\n                        ${industries.map(ind => `<option value=\"${ind}\">${ind}</option>`).join('')}\n                    </select>\n                </td>\n                <td><input type=\"text\" class=\"client-input\" id=\"revenue-${clientId}\" placeholder=\"$XXX,XXX\"></td>\n                <td><input type=\"number\" class=\"client-input score-input\" id=\"value-${clientId}\" min=\"1\" max=\"5\" placeholder=\"1-5\"></td>\n                <td><input type=\"number\" class=\"client-input score-input\" id=\"effort-${clientId}\" min=\"1\" max=\"5\" placeholder=\"1-5\"></td>\n                <td id=\"quadrant-${clientId}\">-</td>\n                <td><button class=\"remove-btn\" onclick=\"removeClient(${clientId})\">âœ•</button></td>\n            `;\n            \n            tbody.appendChild(row);\n        }\n        \n        function removeClient(id) {\n            const row = document.getElementById(`client-${id}`);\n            if (row) {\n                row.remove();\n            }\n        }\n        \n        function generateMatrix() {\n            // Collect all client data\n            clients = [];\n            const rows = document.querySelectorAll('#clientTableBody tr');\n            \n            rows.forEach(row => {\n                const id = row.id.split('-')[1];\n                const name = document.getElementById(`name-${id}`).value;\n                const industry = document.getElementById(`industry-${id}`).value;\n                const revenue = document.getElementById(`revenue-${id}`).value;\n                const value = parseInt(document.getElementById(`value-${id}`).value);\n                const effort = parseInt(document.getElementById(`effort-${id}`).value);\n                \n                if (name && value && effort) {\n                    let quadrant = '';\n                    if (value >= 3 && effort <= 2) quadrant = 'IDEAL';\n                    else if (value >= 3 && effort >= 3) quadrant = 'DEVELOP';\n                    else if (value <= 2 && effort >= 3) quadrant = 'EXIT';\n                    else quadrant = 'AUTOMATE';\n                    \n                    document.getElementById(`quadrant-${id}`).textContent = quadrant;\n                    \n                    clients.push({\n                        id, name, industry, revenue, value, effort, quadrant\n                    });\n                }\n            });\n            \n            if (clients.length === 0) {\n                alert('Please add and score at least one client');\n                return;\n            }\n            \n            // Display matrix and analysis\n            displayMatrix();\n            displayAnalysis();\n            generateActionPlan();\n            \n            // Show sections\n            document.getElementById('matrixSection').style.display = 'block';\n            document.getElementById('analysisSection').style.display = 'block';\n            document.getElementById('actionSection').style.display = 'block';\n            \n            // Scroll to matrix\n            document.getElementById('matrixSection').scrollIntoView({ behavior: 'smooth' });\n        }\n        \n        function displayMatrix() {\n            const grid = document.getElementById('matrixGrid');\n            \n            // Clear existing dots\n            document.querySelectorAll('.client-dot').forEach(dot => dot.remove());\n            \n            // Add client dots\n            clients.forEach((client, index) => {\n                const dot = document.createElement('div');\n                dot.className = 'client-dot';\n                dot.textContent = index + 1;\n                \n                // Calculate position (with some randomization to avoid overlap)\n                const xBase = (client.value / 5) * 50;\n                const yBase = ((5 - client.effort) / 5) * 50;\n                const xOffset = (Math.random() - 0.5) * 10;\n                const yOffset = (Math.random() - 0.5) * 10;\n                \n                const x = xBase + xOffset + (client.value > 2.5 ? 50 : 0);\n                const y = yBase + yOffset + (client.effort < 3 ? 0 : 50);\n                \n                dot.style.left = `${x}%`;\n                dot.style.bottom = `${y}%`;\n                \n                // Color based on quadrant\n                if (client.quadrant === 'IDEAL') dot.style.background = '#48bb78';\n                else if (client.quadrant === 'DEVELOP') dot.style.background = '#f6e05e';\n                else if (client.quadrant === 'EXIT') dot.style.background = '#fc8181';\n                else dot.style.background = '#667eea';\n                \n                // Tooltip\n                dot.onmouseover = (e) => showTooltip(e, client);\n                dot.onmouseout = () => hideTooltip();\n                \n                grid.appendChild(dot);\n            });\n        }\n        \n        function showTooltip(event, client) {\n            const tooltip = document.getElementById('clientTooltip');\n            tooltip.innerHTML = `\n                <strong>${client.name}</strong><br>\n                ${client.industry}<br>\n                Value: ${client.value} | Effort: ${client.effort}<br>\n                ${client.quadrant}\n            `;\n            tooltip.style.display = 'block';\n            tooltip.style.left = event.pageX + 10 + 'px';\n            tooltip.style.top = event.pageY - 30 + 'px';\n        }\n        \n        function hideTooltip() {\n            document.getElementById('clientTooltip').style.display = 'none';\n        }\n        \n        function displayAnalysis() {\n            const counts = {\n                IDEAL: 0,\n                DEVELOP: 0,\n                EXIT: 0,\n                AUTOMATE: 0\n            };\n            \n            clients.forEach(client => {\n                counts[client.quadrant]++;\n            });\n            \n            document.getElementById('idealCount').textContent = counts.IDEAL;\n            document.getElementById('developCount').textContent = counts.DEVELOP;\n            document.getElementById('exitCount').textContent = counts.EXIT;\n            document.getElementById('automateCount').textContent = counts.AUTOMATE;\n        }\n        \n        function generateActionPlan() {\n            const idealClients = clients.filter(c => c.quadrant === 'IDEAL');\n            const developClients = clients.filter(c => c.quadrant === 'DEVELOP');\n            const exitClients = clients.filter(c => c.quadrant === 'EXIT');\n            \n            // Immediate actions\n            const immediateList = document.getElementById('immediateActions');\n            immediateList.innerHTML = '';\n            if (idealClients.length > 0) {\n                immediateList.innerHTML += `<li>â€¢ Contact ${idealClients[0].name} to discuss advisory services</li>`;\n            }\n            if (exitClients.length > 0) {\n                immediateList.innerHTML += `<li>â€¢ Review engagement with ${exitClients[0].name}</li>`;\n            }\n            immediateList.innerHTML += '<li>â€¢ Document current processes for top clients</li>';\n            \n            // 30-day actions\n            const thirtyList = document.getElementById('thirtyDayActions');\n            thirtyList.innerHTML = '';\n            thirtyList.innerHTML += `<li>â€¢ Approach ${Math.min(3, idealClients.length)} ideal clients with proposals</li>`;\n            thirtyList.innerHTML += '<li>â€¢ Standardize service offerings</li>';\n            thirtyList.innerHTML += '<li>â€¢ Set up technology stack</li>';\n            \n            // 90-day goals\n            const ninetyList = document.getElementById('ninetyDayActions');\n            ninetyList.innerHTML = '';\n            ninetyList.innerHTML += `<li>â€¢ Convert ${Math.min(5, idealClients.length)} clients to advisory</li>`;\n            ninetyList.innerHTML += `<li>â€¢ Exit or transition ${Math.min(3, exitClients.length)} low-value clients</li>`;\n            ninetyList.innerHTML += '<li>â€¢ Achieve 3x revenue on advisory clients</li>';\n        }\n        \n        function exportData() {\n            let csv = 'Client Name,Industry,Revenue,Value Score,Effort Score,Quadrant\\n';\n            clients.forEach(client => {\n                csv += `\"${client.name}\",\"${client.industry}\",\"${client.revenue}\",${client.value},${client.effort},${client.quadrant}\\n`;\n            });\n            \n            const blob = new Blob([csv], { type: 'text/csv' });\n            const url = window.URL.createObjectURL(blob);\n            const a = document.createElement('a');\n            a.href = url;\n            a.download = 'client_evaluation.csv';\n            a.click();\n        }\n        \n        function resetAll() {\n            if (confirm('This will clear all client data. Are you sure?')) {\n                document.getElementById('clientTableBody').innerHTML = '';\n                document.getElementById('matrixSection').style.display = 'none';\n                document.getElementById('analysisSection').style.display = 'none';\n                document.getElementById('actionSection').style.display = 'none';\n                clients = [];\n                clientId = 0;\n            }\n        }\n        \n        // Add 5 sample clients on load\n        window.onload = function() {\n            for (let i = 0; i < 5; i++) {\n                addClient();\n            }\n        };\n    </script>\n</body>\n</html>"
  }
