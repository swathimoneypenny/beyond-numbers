{
  "schemaVersion": "1.0",
  "id": "s2-ex1-team-52-card-pickup",
  "session": 2,
  "exercise": 1,
  "title": "52-Card Team Pickup",
  "type": "cardsort",
  "summary": "Team-building card exercise: sort responsibilities across the four roles (BOS / Admin / Analyst / Technical) to expose gaps and frame the next hire.",
  "interactive": true,
  "brand": {
    "deepPurple": "#574A9E",
    "gold": "#E6B450",
    "teal": "#4ECDC4",
    "gradient": [
      "#667EEA",
      "#764BA2"
    ],
    "font": "Calibri"
