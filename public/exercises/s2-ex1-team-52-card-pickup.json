  "embed": {
    "format": "html",
    "selfContained": true,
    "markup": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Team Building Exercise - 52 Card Pickup</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            min-height: 100vh;\n            padding: 20px;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            background: white;\n            border-radius: 20px;\n            padding: 40px;\n            box-shadow: 0 20px 60px rgba(0,0,0,0.3);\n        }\n        \n        .header {\n            text-align: center;\n            margin-bottom: 30px;\n        }\n        \n        .header h1 {\n            color: #667eea;\n            font-size: 36px;\n            margin-bottom: 10px;\n        }\n        \n        .header p {\n            color: #718096;\n            font-size: 18px;\n        }\n        \n        .timer-section {\n            text-align: center;\n            margin: 30px 0;\n        }\n        \n        .timer-display {\n            font-size: 48px;\n            color: #667eea;\n            font-weight: bold;\n            display: none;\n            animation: pulse 1s infinite;\n        }\n        \n        @keyframes pulse {\n            0%, 100% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n        }\n        \n        .control-buttons {\n            display: flex;\n            justify-content: center;\n            gap: 20px;\n            margin: 30px 0;\n        }\n        \n        .btn {\n            padding: 15px 30px;\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: white;\n            border: none;\n            border-radius: 10px;\n            font-size: 16px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n        }\n        \n        .btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);\n        }\n        \n        .btn:disabled {\n            opacity: 0.5;\n            cursor: not-allowed;\n        }\n        \n        .cards-container {\n            background: #f7fafc;\n            border-radius: 15px;\n            padding: 30px;\n            margin: 30px 0;\n            min-height: 300px;\n            position: relative;\n        }\n        \n        .task-card {\n            display: inline-block;\n            background: white;\n            border: 2px solid #e2e8f0;\n            border-radius: 8px;\n            padding: 10px 15px;\n            margin: 5px;\n            cursor: grab;\n            transition: all 0.3s ease;\n            position: relative;\n            user-select: none;\n        }\n        \n        .task-card:active {\n            cursor: grabbing;\n        }\n        \n        .task-card.dragging {\n            opacity: 0.5;\n            transform: scale(1.1);\n            z-index: 1000;\n        }\n        \n        .task-card.scattered {\n            position: absolute;\n            animation: scatter 0.5s ease-out forwards;\n        }\n        \n        @keyframes scatter {\n            from {\n                transform: translate(0, 0) rotate(0deg);\n            }\n            to {\n                transform: translate(var(--x), var(--y)) rotate(var(--r));\n            }\n        }\n        \n        .buckets-container {\n            display: grid;\n            grid-template-columns: repeat(2, 1fr);\n            gap: 20px;\n            margin: 30px 0;\n        }\n        \n        .bucket {\n            background: white;\n            border: 3px dashed #cbd5e0;\n            border-radius: 15px;\n            padding: 20px;\n            min-height: 200px;\n            transition: all 0.3s ease;\n        }\n        \n        .bucket.drag-over {\n            background: #e6f4ff;\n            border-color: #667eea;\n            transform: scale(1.02);\n        }\n        \n        .bucket-header {\n            display: flex;\n            align-items: center;\n            gap: 10px;\n            margin-bottom: 15px;\n            padding-bottom: 10px;\n            border-bottom: 2px solid #e2e8f0;\n        }\n        \n        .bucket-icon {\n            font-size: 32px;\n        }\n        \n        .bucket-title {\n            font-size: 18px;\n            font-weight: bold;\n        }\n        \n        .bucket-subtitle {\n            font-size: 12px;\n            color: #718096;\n        }\n        \n        .bucket-content {\n            min-height: 100px;\n            padding: 10px;\n        }\n        \n        .bucket-count {\n            position: absolute;\n            top: 10px;\n            right: 10px;\n            background: #667eea;\n            color: white;\n            padding: 5px 10px;\n            border-radius: 20px;\n            font-size: 14px;\n            font-weight: bold;\n        }\n        \n        #bosBucket {\n            border-color: #667eea;\n        }\n        \n        #adminBucket {\n            border-color: #4ecdc4;\n        }\n        \n        #analystBucket {\n            border-color: #f6e05e;\n        }\n        \n        #technicalBucket {\n            border-color: #fc8181;\n        }\n        \n        .results-section {\n            background: linear-gradient(135deg, #e6f4ff 0%, #b3d9ff 100%);\n            border-radius: 15px;\n            padding: 30px;\n            margin: 30px 0;\n            display: none;\n        }\n        \n        .results-section.show {\n            display: block;\n            animation: fadeIn 0.5s ease-out;\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        \n        .stats-grid {\n            display: grid;\n            grid-template-columns: repeat(4, 1fr);\n            gap: 15px;\n            margin: 20px 0;\n        }\n        \n        .stat-card {\n            background: white;\n            padding: 20px;\n            border-radius: 10px;\n            text-align: center;\n        }\n        \n        .stat-value {\n            font-size: 36px;\n            font-weight: bold;\n            color: #667eea;\n        }\n        \n        .stat-label {\n            font-size: 14px;\n            color: #718096;\n            margin-top: 5px;\n        }\n        \n        .instructions {\n            background: #fef5e7;\n            border: 2px solid #f6e05e;\n            border-radius: 10px;\n            padding: 20px;\n            margin: 20px 0;\n        }\n        \n        .instructions h3 {\n            color: #744210;\n            margin-bottom: 10px;\n        }\n        \n        .instructions ol {\n            margin-left: 20px;\n            line-height: 1.8;\n        }\n        \n        .reset-btn {\n            background: linear-gradient(135deg, #fc8181 0%, #f56565 100%);\n        }\n        \n        .success-message {\n            background: #48bb78;\n            color: white;\n            padding: 15px;\n            border-radius: 10px;\n            text-align: center;\n            font-size: 18px;\n            margin: 20px 0;\n            display: none;\n        }\n        \n        .success-message.show {\n            display: block;\n            animation: slideDown 0.5s ease-out;\n        }\n        \n        @keyframes slideDown {\n            from { transform: translateY(-20px); opacity: 0; }\n            to { transform: translateY(0); opacity: 1; }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>ðŸƒ The 52-Card Team Pickup Exercise</h1>\n            <p>Discover how your tasks should be distributed across your dream team</p>\n        </div>\n        \n        <div class=\"instructions\">\n            <h3>ðŸ“‹ How to Play:</h3>\n            <ol>\n                <li>Click \"Scatter Tasks\" to see all the tasks your firm currently handles</li>\n                <li>Start the 2-minute timer when ready</li>\n                <li>Drag each task card to the appropriate team member bucket</li>\n                <li>Review your results to see where bottlenecks exist</li>\n            </ol>\n        </div>\n        \n        <div class=\"control-buttons\">\n            <button class=\"btn\" id=\"scatterBtn\" onclick=\"scatterTasks()\">\n                ðŸŽ² Scatter Tasks\n            </button>\n            <button class=\"btn\" id=\"timerBtn\" onclick=\"startTimer()\">\n                â±ï¸ Start 2-Minute Timer\n            </button>\n            <button class=\"btn reset-btn\" onclick=\"resetExercise()\">\n                ðŸ”„ Reset Exercise\n            </button>\n        </div>\n        \n        <div class=\"timer-section\">\n            <div class=\"timer-display\" id=\"timerDisplay\">2:00</div>\n        </div>\n        \n        <div class=\"cards-container\" id=\"cardsContainer\">\n            <!-- Task cards will be dynamically added here -->\n        </div>\n        \n        <div class=\"buckets-container\" id=\"bucketsContainer\" style=\"display: none;\">\n            <div class=\"bucket\" id=\"bosBucket\" ondrop=\"drop(event, 'bos')\" ondragover=\"allowDrop(event)\" ondragleave=\"dragLeave(event)\">\n                <div class=\"bucket-header\">\n                    <span class=\"bucket-icon\">ðŸŽ¯</span>\n                    <div>\n                        <div class=\"bucket-title\">BOS Tasks</div>\n                        <div class=\"bucket-subtitle\">Strategic & Advisory</div>\n                    </div>\n                </div>\n                <div class=\"bucket-content\" id=\"bosContent\"></div>\n            </div>\n            \n            <div class=\"bucket\" id=\"adminBucket\" ondrop=\"drop(event, 'admin')\" ondragover=\"allowDrop(event)\" ondragleave=\"dragLeave(event)\">\n                <div class=\"bucket-header\">\n                    <span class=\"bucket-icon\">âš™ï¸</span>\n                    <div>\n                        <div class=\"bucket-title\">Admin Tasks</div>\n                        <div class=\"bucket-subtitle\">Coordination & Process</div>\n                    </div>\n                </div>\n                <div class=\"bucket-content\" id=\"adminContent\"></div>\n            </div>\n            \n            <div class=\"bucket\" id=\"analystBucket\" ondrop=\"drop(event, 'analyst')\" ondragover=\"allowDrop(event)\" ondragleave=\"dragLeave(event)\">\n                <div class=\"bucket-header\">\n                    <span class=\"bucket-icon\">ðŸ”¬</span>\n                    <div>\n                        <div class=\"bucket-title\">Business Analyst Tasks</div>\n                        <div class=\"bucket-subtitle\">Technology & Analysis</div>\n                    </div>\n                </div>\n                <div class=\"bucket-content\" id=\"analystContent\"></div>\n            </div>\n            \n            <div class=\"bucket\" id=\"technicalBucket\" ondrop=\"drop(event, 'technical')\" ondragover=\"allowDrop(event)\" ondragleave=\"dragLeave(event)\">\n                <div class=\"bucket-header\">\n                    <span class=\"bucket-icon\">ðŸ“š</span>\n                    <div>\n                        <div class=\"bucket-title\">Technical Tasks</div>\n                        <div class=\"bucket-subtitle\">Accounting & Tax</div>\n                    </div>\n                </div>\n                <div class=\"bucket-content\" id=\"technicalContent\"></div>\n            </div>\n        </div>\n        \n        <div class=\"success-message\" id=\"successMessage\">\n            ðŸŽ‰ Excellent work! You've organized all tasks. Check your results below.\n        </div>\n        \n        <div class=\"results-section\" id=\"resultsSection\">\n            <h2 style=\"text-align: center; color: #2d3748; margin-bottom: 20px;\">\n                ðŸ“Š Your Task Distribution Analysis\n            </h2>\n            \n            <div class=\"stats-grid\">\n                <div class=\"stat-card\">\n                    <div class=\"stat-value\" id=\"bosPercent\">0%</div>\n                    <div class=\"stat-label\">BOS/Strategic</div>\n                </div>\n                <div class=\"stat-card\">\n                    <div class=\"stat-value\" id=\"adminPercent\">0%</div>\n                    <div class=\"stat-label\">Admin/Process</div>\n                </div>\n                <div class=\"stat-card\">\n                    <div class=\"stat-value\" id=\"analystPercent\">0%</div>\n                    <div class=\"stat-label\">Analysis/Tech</div>\n                </div>\n                <div class=\"stat-card\">\n                    <div class=\"stat-value\" id=\"technicalPercent\">0%</div>\n                    <div class=\"stat-label\">Technical/Tax</div>\n                </div>\n            </div>\n            \n            <div style=\"background: white; padding: 20px; border-radius: 10px; margin-top: 20px;\">\n                <h3 style=\"color: #667eea; margin-bottom: 15px;\">ðŸŽ¯ Ideal Target Distribution:</h3>\n                <ul style=\"list-style: none; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 10px;\">\n                    <li>â€¢ BOS/Strategic: 40-50%</li>\n                    <li>â€¢ Admin/Process: 20-25%</li>\n                    <li>â€¢ Analysis/Tech: 15-20%</li>\n                    <li>â€¢ Technical/Tax: 15-20%</li>\n                </ul>\n            </div>\n            \n            <div style=\"background: #f0fff4; padding: 20px; border-radius: 10px; margin-top: 20px;\">\n                <h3 style=\"color: #22543d; margin-bottom: 10px;\">ðŸ’¡ Key Insight:</h3>\n                <p id=\"insightText\" style=\"line-height: 1.6;\">Analyzing your distribution...</p>\n            </div>\n        </div>\n    </div>\n    \n    <script>\n        // Task definitions with their ideal bucket assignments\n        const tasks = [\n            { id: 1, text: \"Client strategy calls\", ideal: \"bos\" },\n            { id: 2, text: \"Bank reconciliations\", ideal: \"technical\" },\n            { id: 3, text: \"Workflow setup\", ideal: \"admin\" },\n            { id: 4, text: \"App evaluation\", ideal: \"analyst\" },\n            { id: 5, text: \"Tax return prep\", ideal: \"technical\" },\n            { id: 6, text: \"Document collection\", ideal: \"admin\" },\n            { id: 7, text: \"KPI dashboards\", ideal: \"analyst\" },\n            { id: 8, text: \"Cash flow forecasts\", ideal: \"bos\" },\n            { id: 9, text: \"Meeting scheduling\", ideal: \"admin\" },\n            { id: 10, text: \"Data entry\", ideal: \"technical\" },\n            { id: 11, text: \"Client onboarding\", ideal: \"admin\" },\n            { id: 12, text: \"Financial reviews\", ideal: \"bos\" },\n            { id: 13, text: \"Payroll processing\", ideal: \"technical\" },\n            { id: 14, text: \"Training delivery\", ideal: \"bos\" },\n            { id: 15, text: \"Business planning\", ideal: \"bos\" },\n            { id: 16, text: \"Tech support\", ideal: \"analyst\" },\n            { id: 17, text: \"Compliance filing\", ideal: \"technical\" },\n            { id: 18, text: \"Invoice management\", ideal: \"admin\" },\n            { id: 19, text: \"Client communication\", ideal: \"admin\" },\n            { id: 20, text: \"Process optimization\", ideal: \"analyst\" },\n            { id: 21, text: \"Budget analysis\", ideal: \"bos\" },\n            { id: 22, text: \"Journal entries\", ideal: \"technical\" },\n            { id: 23, text: \"Software implementation\", ideal: \"analyst\" },\n            { id: 24, text: \"Team coordination\", ideal: \"admin\" }\n        ];\n        \n        let timer = null;\n        let timeLeft = 120;\n        let tasksScattered = false;\n        \n        function scatterTasks() {\n            const container = document.getElementById('cardsContainer');\n            container.innerHTML = '';\n            \n            tasks.forEach((task, index) => {\n                const card = document.createElement('div');\n                card.className = 'task-card';\n                card.id = `task-${task.id}`;\n                card.draggable = true;\n                card.textContent = task.text;\n                card.dataset.ideal = task.ideal;\n                card.ondragstart = (e) => dragStart(e);\n                card.ondragend = (e) => dragEnd(e);\n                \n                // Random positioning for scatter effect\n                const x = Math.random() * 80 - 40;\n                const y = Math.random() * 150 - 75;\n                const r = Math.random() * 30 - 15;\n                \n                card.style.setProperty('--x', `${x}px`);\n                card.style.setProperty('--y', `${y}px`);\n                card.style.setProperty('--r', `${r}deg`);\n                \n                container.appendChild(card);\n                \n                setTimeout(() => {\n                    card.classList.add('scattered');\n                }, index * 50);\n            });\n            \n            document.getElementById('bucketsContainer').style.display = 'grid';\n            tasksScattered = true;\n            document.getElementById('scatterBtn').disabled = true;\n        }\n        \n        function startTimer() {\n            if (!tasksScattered) {\n                alert('Please scatter the tasks first!');\n                return;\n            }\n            \n            if (timer) return;\n            \n            const display = document.getElementById('timerDisplay');\n            display.style.display = 'block';\n            timeLeft = 120;\n            \n            timer = setInterval(() => {\n                const minutes = Math.floor(timeLeft / 60);\n                const seconds = timeLeft % 60;\n                display.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;\n                \n                if (timeLeft <= 0) {\n                    clearInterval(timer);\n                    timer = null;\n                    display.textContent = \"Time's Up!\";\n                    calculateResults();\n                }\n                \n                timeLeft--;\n            }, 1000);\n            \n            document.getElementById('timerBtn').disabled = true;\n        }\n        \n        function dragStart(e) {\n            e.dataTransfer.effectAllowed = 'move';\n            e.dataTransfer.setData('text/html', e.target.id);\n            e.target.classList.add('dragging');\n        }\n        \n        function dragEnd(e) {\n            e.target.classList.remove('dragging');\n        }\n        \n        function allowDrop(e) {\n            e.preventDefault();\n            e.currentTarget.classList.add('drag-over');\n        }\n        \n        function dragLeave(e) {\n            e.currentTarget.classList.remove('drag-over');\n        }\n        \n        function drop(e, bucket) {\n            e.preventDefault();\n            e.currentTarget.classList.remove('drag-over');\n            \n            const taskId = e.dataTransfer.getData('text/html');\n            const task = document.getElementById(taskId);\n            \n            if (task) {\n                task.classList.remove('scattered');\n                task.style.position = 'relative';\n                task.style.transform = 'none';\n                \n                const content = document.getElementById(`${bucket}Content`);\n                content.appendChild(task);\n                \n                checkCompletion();\n            }\n        }\n        \n        function checkCompletion() {\n            const container = document.getElementById('cardsContainer');\n            if (container.children.length === 0) {\n                document.getElementById('successMessage').classList.add('show');\n                if (timer) {\n                    clearInterval(timer);\n                    timer = null;\n                }\n                calculateResults();\n            }\n        }\n        \n        function calculateResults() {\n            const buckets = {\n                bos: document.getElementById('bosContent').children.length,\n                admin: document.getElementById('adminContent').children.length,\n                analyst: document.getElementById('analystContent').children.length,\n                technical: document.getElementById('technicalContent').children.length\n            };\n            \n            const total = tasks.length;\n            \n            document.getElementById('bosPercent').textContent = \n                Math.round((buckets.bos / total) * 100) + '%';\n            document.getElementById('adminPercent').textContent = \n                Math.round((buckets.admin / total) * 100) + '%';\n            document.getElementById('analystPercent').textContent = \n                Math.round((buckets.analyst / total) * 100) + '%';\n            document.getElementById('technicalPercent').textContent = \n                Math.round((buckets.technical / total) * 100) + '%';\n            \n            // Generate insight\n            let insight = \"\";\n            const bosPercent = (buckets.bos / total) * 100;\n            const adminPercent = (buckets.admin / total) * 100;\n            \n            if (bosPercent < 30) {\n                insight = \"âš ï¸ Your BOS/Strategic allocation is too low. You're likely stuck in operational tasks instead of advisory work. Consider delegating more technical tasks.\";\n            } else if (bosPercent > 50) {\n                insight = \"âœ… Great strategic focus! Make sure you have adequate support for execution.\";\n            } else {\n                insight = \"ðŸ‘ Good balance! Fine-tune by moving a few more operational tasks to admin/technical roles.\";\n            }\n            \n            if (adminPercent < 15) {\n                insight += \" Consider strengthening your administrative support to free up professional time.\";\n            }\n            \n            document.getElementById('insightText').textContent = insight;\n            document.getElementById('resultsSection').classList.add('show');\n        }\n        \n        function resetExercise() {\n            // Clear everything\n            document.getElementById('cardsContainer').innerHTML = '';\n            document.getElementById('bosContent').innerHTML = '';\n            document.getElementById('adminContent').innerHTML = '';\n            document.getElementById('analystContent').innerHTML = '';\n            document.getElementById('technicalContent').innerHTML = '';\n            \n            // Reset states\n            tasksScattered = false;\n            document.getElementById('scatterBtn').disabled = false;\n            document.getElementById('timerBtn').disabled = false;\n            document.getElementById('bucketsContainer').style.display = 'none';\n            document.getElementById('timerDisplay').style.display = 'none';\n            document.getElementById('successMessage').classList.remove('show');\n            document.getElementById('resultsSection').classList.remove('show');\n            \n            // Clear timer\n            if (timer) {\n                clearInterval(timer);\n                timer = null;\n            }\n            timeLeft = 120;\n            document.getElementById('timerDisplay').textContent = '2:00';\n        }\n    </script>\n</body>\n</html>"
  }
}