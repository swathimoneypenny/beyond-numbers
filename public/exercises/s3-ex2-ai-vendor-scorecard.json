{
  "schemaVersion": "1.0",
  "id": "s3-ex2-ai-vendor-scorecard",
  "session": 3,
  "exercise": 2,
  "title": "AI Vendor Due-Diligence Scorecard",
  "type": "scorecard",
  "summary": "Score one AI tool across six areas (three critical) before client data is involved; auto Go / Conditional / No-Go verdict, any critical Red forces No-Go.",
  "interactive": true,
  "brand": {
    "deepPurple": "#574A9E",
    "gold": "#E6B450",
    "teal": "#4ECDC4",
    "gradient": [
      "#667EEA",
      "#764BA2"
    ],
    "font": "Calibri"
  },
  "embed": {
    "format": "html",
    "selfContained": true,
    "markup": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Exercise 2 — AI Vendor Due-Diligence Scorecard | Session 3</title>\n<style>\n  :root{\n    --deep:#574A9E; --grad1:#667EEA; --grad2:#764BA2;\n    --gold:#E6B450; --teal:#4ECDC4; --coral:#FF6B6B;\n    --slate:#2D3748; --mute:#718096; --card:#F4F4FB; --line:#E2E0F0;\n    --green:#2F9E6B; --amber:#E6A23C; --red:#E05C5C;\n  }\n  *{margin:0;padding:0;box-sizing:border-box;}\n  body{font-family:'Calibri','Segoe UI',Tahoma,sans-serif;background:linear-gradient(135deg,var(--grad1) 0%,var(--grad2) 100%);min-height:100vh;padding:22px;color:var(--slate);}\n  .wrap{max-width:1320px;margin:0 auto;}\n  header{background:linear-gradient(135deg,var(--grad1) 0%,var(--grad2) 100%);color:#fff;border-radius:18px;padding:26px 30px;margin-bottom:20px;display:flex;justify-content:space-between;align-items:center;box-shadow:0 12px 34px rgba(0,0,0,.25);}\n  header .eyebrow{font-size:13px;font-weight:700;letter-spacing:4px;color:var(--gold);}\n  header h1{font-size:29px;margin:6px 0 4px;}\n  header p{opacity:.9;font-size:14.5px;max-width:720px;}\n  .timer-box{background:var(--gold);color:#5A4A12;border-radius:14px;padding:14px 24px;text-align:center;min-width:160px;}\n  .timer-box .lbl{font-size:12px;font-weight:700;letter-spacing:1px;opacity:.85;}\n  .timer-box .disp{font-size:38px;font-weight:800;line-height:1;margin:2px 0;}\n  .timer-btn{margin-top:3px;padding:5px 16px;background:#5A4A12;color:#fff;border:none;border-radius:20px;cursor:pointer;font-weight:700;font-size:13px;}\n  /* meta bar */\n  .meta{background:#fff;border-radius:16px;padding:18px 22px;margin-bottom:20px;display:grid;grid-template-columns:repeat(4,1fr);gap:16px;box-shadow:0 10px 30px rgba(40,30,90,.16);}\n  .meta label{display:block;font-size:12px;font-weight:700;color:var(--deep);margin-bottom:5px;letter-spacing:.5px;}\n  .meta input{width:100%;border:2px solid var(--line);border-radius:9px;padding:9px 11px;font-family:inherit;font-size:14px;color:var(--slate);}\n  .meta input:focus{outline:none;border-color:var(--deep);}\n  .layout{display:grid;grid-template-columns:1fr 360px;gap:20px;align-items:start;}\n  .cards{display:grid;grid-template-columns:1fr 1fr;gap:16px;}\n  .area{background:#fff;border-radius:15px;padding:18px;box-shadow:0 8px 24px rgba(40,30,90,.14);border-top:5px solid var(--deep);}\n  .area.crit{border-top-color:var(--coral);}\n  .area .ahead{display:flex;align-items:center;gap:10px;margin-bottom:6px;}\n  .area .anum{width:30px;height:30px;border-radius:50%;background:var(--deep);color:#fff;font-weight:800;font-size:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}\n  .area.crit .anum{background:var(--coral);}\n  .area .atitle{font-weight:700;color:var(--deep);font-size:16px;line-height:1.2;}\n  .crit-tag{display:inline-block;background:#FBEAEA;color:var(--coral);font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;margin-left:4px;letter-spacing:.5px;vertical-align:middle;}\n  .area .ask{font-size:12.5px;color:var(--mute);line-height:1.55;margin:8px 0 12px;}\n  .ryg{display:flex;gap:7px;}\n  .ryg button{flex:1;padding:9px 0;border:2px solid var(--line);border-radius:9px;background:#fff;cursor:pointer;font-weight:700;font-size:12.5px;color:var(--mute);transition:.12s;}\n  .ryg button:hover{border-color:#bbb;}\n  .ryg button.g.on{background:var(--green);border-color:var(--green);color:#fff;}\n  .ryg button.y.on{background:var(--amber);border-color:var(--amber);color:#fff;}\n  .ryg button.r.on{background:var(--red);border-color:var(--red);color:#fff;}\n  .area textarea{width:100%;margin-top:10px;border:2px solid var(--line);border-radius:9px;padding:8px 10px;font-family:inherit;font-size:12.5px;resize:vertical;min-height:42px;color:var(--slate);}\n  .area textarea:focus{outline:none;border-color:var(--deep);}\n  /* verdict panel */\n  .side{position:sticky;top:22px;display:flex;flex-direction:column;gap:18px;}\n  .verdict{background:linear-gradient(160deg,var(--deep) 0%,#3F356F 100%);color:#fff;border-radius:16px;padding:22px;box-shadow:0 10px 30px rgba(40,30,90,.22);}\n  .verdict h2{font-size:17px;border-bottom:3px solid var(--gold);padding-bottom:9px;margin-bottom:14px;}\n  .vbadge{border-radius:13px;padding:18px;text-align:center;margin-bottom:14px;}\n  .vbadge .vt{font-size:26px;font-weight:800;line-height:1.1;}\n  .vbadge .vs{font-size:12.5px;margin-top:5px;opacity:.95;}\n  .vbadge.go{background:var(--green);}\n  .vbadge.cond{background:var(--amber);color:#4A3608;}\n  .vbadge.nogo{background:var(--red);}\n  .vbadge.pending{background:rgba(255,255,255,.14);}\n  .counts{display:flex;gap:8px;margin-bottom:12px;}\n  .count{flex:1;text-align:center;background:rgba(255,255,255,.1);border-radius:10px;padding:9px 0;}\n  .count .n{font-size:22px;font-weight:800;}\n  .count .l{font-size:10.5px;opacity:.8;letter-spacing:.5px;}\n  .count.g .n{color:#7BE3B0;} .count.y .n{color:#F5CE7A;} .count.r .n{color:#F39B9B;}\n  .vnote{font-size:12px;line-height:1.6;opacity:.92;background:rgba(255,255,255,.08);border-radius:10px;padding:11px;}\n  .vbtns{display:flex;gap:8px;margin-top:14px;}\n  .vbtns button{flex:1;padding:10px;border:none;border-radius:9px;font-weight:700;font-size:13px;cursor:pointer;}\n  .vbtns .reset{background:var(--coral);color:#fff;}\n  .vbtns .print{background:var(--gold);color:#5A4A12;}\n  .ref{background:#fff;border-radius:16px;padding:18px;box-shadow:0 8px 24px rgba(40,30,90,.14);border-left:5px solid var(--teal);}\n  .ref h3{color:#2F8276;font-size:14px;margin-bottom:9px;}\n  .ref p{font-size:12.5px;line-height:1.6;color:var(--slate);margin-bottom:8px;}\n  .ref strong{color:var(--deep);}\n  .foot{text-align:center;color:rgba(255,255,255,.82);font-size:12.5px;margin-top:20px;}\n  @media print{\n    body{background:#fff;padding:0;}\n    header{background:var(--deep)!important;-webkit-print-color-adjust:exact;print-color-adjust:exact;}\n    .timer-box,.vbtns{display:none;}\n    .area,.meta,.verdict,.ref{box-shadow:none;}\n    .layout{grid-template-columns:1fr 320px;}\n    .verdict,.vbadge{-webkit-print-color-adjust:exact;print-color-adjust:exact;}\n    .side{position:static;}\n  }\n  @media(max-width:1080px){.layout{grid-template-columns:1fr;}.cards{grid-template-columns:1fr;}.meta{grid-template-columns:1fr 1fr;}.side{position:static;}}\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <header>\n    <div>\n      <div class=\"eyebrow\">SESSION 3 · EXERCISE 2</div>\n      <h1>AI Vendor Due-Diligence Scorecard</h1>\n      <p>Score one AI tool across six areas before any client data goes near it. Any <strong>critical</strong> area rated RED blocks client-data use until it's resolved.</p>\n    </div>\n    <div class=\"timer-box\">\n      <div class=\"lbl\">EXERCISE TIME</div>\n      <div class=\"disp\" id=\"timer\">10:00</div>\n      <button class=\"timer-btn\" onclick=\"startTimer()\">▶ Start</button>\n    </div>\n  </header>\n\n  <div class=\"meta\">\n    <div><label>AI TOOL / VENDOR</label><input id=\"m_vendor\" placeholder=\"e.g., Booke AI\"></div>\n    <div><label>INTENDED USE CASE</label><input id=\"m_use\" placeholder=\"e.g., transaction categorization\"></div>\n    <div><label>REVIEWER</label><input id=\"m_rev\" placeholder=\"Your name\"></div>\n    <div><label>DATE</label><input id=\"m_date\" placeholder=\"mm/dd/yyyy\"></div>\n  </div>\n\n  <div class=\"layout\">\n    <div class=\"cards\" id=\"cards\"></div>\n\n    <div class=\"side\">\n      <div class=\"verdict\">\n        <h2>Overall Verdict</h2>\n        <div class=\"vbadge pending\" id=\"vbadge\"><div class=\"vt\" id=\"vt\">— —</div><div class=\"vs\" id=\"vs\">Score all six areas</div></div>\n        <div class=\"counts\">\n          <div class=\"count g\"><div class=\"n\" id=\"cg\">0</div><div class=\"l\">GREEN</div></div>\n          <div class=\"count y\"><div class=\"n\" id=\"cy\">0</div><div class=\"l\">YELLOW</div></div>\n          <div class=\"count r\"><div class=\"n\" id=\"cr\">0</div><div class=\"l\">RED</div></div>\n        </div>\n        <div class=\"vnote\" id=\"vnote\">Rate each area Green (approved), Yellow (conditions to clear), or Red (blocked). Areas marked CRITICAL govern whether client data may be used at all.</div>\n        <div class=\"vbtns\">\n          <button class=\"reset\" onclick=\"resetAll()\">Reset</button>\n          <button class=\"print\" onclick=\"window.print()\">Print / Save PDF</button>\n        </div>\n      </div>\n      <div class=\"ref\">\n        <h3>Why this matters</h3>\n        <p>Before any AI tool touches client work, the <strong>AICPA Confidential Client Information Rule (§1.700.001)</strong> applies.</p>\n        <p>This scorecard operationalizes <strong>NIST's AI RMF</strong> — govern, map, measure, manage — into a go/no-go you can document and keep as evidence.</p>\n        <p><strong>Start narrow:</strong> one workflow, one owner, one client-data category, one review rule, one evidence location.</p>\n      </div>\n    </div>\n  </div>\n  <div class=\"foot\">From Scorekeeper to Strategist · Session 3: Technology &amp; AI · Beyond Numbers — a starter AI-governance record. Keep the printed scorecard with your vendor file.</div>\n</div>\n\n<script>\n  const AREAS = [\n    { key:\"data\", title:\"Client-Data Exposure\", crit:true,\n      ask:\"What client data would the tool see? Where is it stored, for how long, and who can access it? Can data be deleted on request?\" },\n    { key:\"train\", title:\"Model-Training Risk\", crit:true,\n      ask:\"Does the vendor train its models on your data or use it to improve their product? Can you opt out — and is that opt-out the default?\" },\n    { key:\"conf\", title:\"Confidentiality & Disclosure Fit\", crit:true,\n      ask:\"Does this use comply with AICPA §1.700.001? Do your engagement letters cover AI use, client consent, and an opt-out?\" },\n    { key:\"acc\", title:\"Accuracy & Review Controls\", crit:false,\n      ask:\"Are outputs explainable / citation-backed? Is there a defined human-review step and a confidence threshold before anything is relied on?\" },\n    { key:\"audit\", title:\"Audit-Trail Quality\", crit:false,\n      ask:\"Does it log inputs, outputs, and who did what? Could you reproduce a result for a reviewer or regulator months later?\" },\n    { key:\"contract\", title:\"Contract & Security Evidence\", crit:false,\n      ask:\"SOC 2 Type II? Subprocessors disclosed? Data Processing Agreement available? Data deletion guaranteed on termination?\" },\n  ];\n\n  const score = {}; AREAS.forEach(a=>score[a.key]=null);\n\n  const cardsEl=document.getElementById(\"cards\");\n  AREAS.forEach((a,i)=>{\n    const c=document.createElement(\"div\");\n    c.className=\"area\"+(a.crit?\" crit\":\"\");\n    c.innerHTML=`\n      <div class=\"ahead\">\n        <div class=\"anum\">${i+1}</div>\n        <div class=\"atitle\">${a.title}${a.crit?'<span class=\"crit-tag\">CRITICAL</span>':''}</div>\n      </div>\n      <div class=\"ask\">${a.ask}</div>\n      <div class=\"ryg\">\n        <button class=\"g\" onclick=\"rate('${a.key}','g',this)\">Green</button>\n        <button class=\"y\" onclick=\"rate('${a.key}','y',this)\">Yellow</button>\n        <button class=\"r\" onclick=\"rate('${a.key}','r',this)\">Red</button>\n      </div>\n      <textarea placeholder=\"Evidence / notes (e.g., link to vendor security page, DPA, opt-out setting)\"></textarea>`;\n    cardsEl.appendChild(c);\n  });\n\n  function rate(key,val,btn){\n    const row=btn.parentElement;\n    row.querySelectorAll(\"button\").forEach(b=>b.classList.remove(\"on\"));\n    btn.classList.add(\"on\");\n    score[key]=val;\n    update();\n  }\n\n  function update(){\n    let g=0,y=0,r=0,done=0, critRed=false;\n    AREAS.forEach(a=>{\n      const v=score[a.key];\n      if(v){ done++; if(v===\"g\")g++; else if(v===\"y\")y++; else { r++; if(a.crit) critRed=true; } }\n    });\n    document.getElementById(\"cg\").textContent=g;\n    document.getElementById(\"cy\").textContent=y;\n    document.getElementById(\"cr\").textContent=r;\n\n    const badge=document.getElementById(\"vbadge\"), vt=document.getElementById(\"vt\"), vs=document.getElementById(\"vs\"), vnote=document.getElementById(\"vnote\");\n    badge.className=\"vbadge\";\n    if(done<AREAS.length){\n      badge.classList.add(\"pending\");\n      vt.textContent=\"— —\"; vs.textContent=`Scored ${done} of ${AREAS.length} areas`;\n      vnote.textContent=\"Finish scoring all six areas to get a verdict.\";\n      return;\n    }\n    if(critRed){\n      badge.classList.add(\"nogo\");\n      vt.textContent=\"NO-GO\"; vs.textContent=\"Blocked — do not use on client data\";\n      vnote.textContent=\"A critical area is RED. Client data must not enter this tool until the vendor resolves it. Document the gap and re-score after they respond.\";\n    } else if(r>0 || y>0){\n      badge.classList.add(\"cond\");\n      vt.textContent=\"CONDITIONAL\"; vs.textContent=\"Approved with conditions\";\n      vnote.textContent=\"No critical reds, but open items remain. List the conditions to clear, assign an owner, and set a review date before going live.\";\n    } else {\n      badge.classList.add(\"go\");\n      vt.textContent=\"GO\"; vs.textContent=\"Approved for the defined use\";\n      vnote.textContent=\"All areas green for this narrow use case. Keep this scorecard on file, name the owner, and re-score if the use case or vendor terms change.\";\n    }\n  }\n\n  function resetAll(){\n    AREAS.forEach(a=>score[a.key]=null);\n    document.querySelectorAll(\".ryg button\").forEach(b=>b.classList.remove(\"on\"));\n    document.querySelectorAll(\".area textarea\").forEach(t=>t.value=\"\");\n    update();\n  }\n\n  let ti=null;\n  function startTimer(){\n    if(ti) clearInterval(ti);\n    let left=600; const d=document.getElementById(\"timer\");\n    ti=setInterval(()=>{\n      left--; const m=Math.floor(left/60), s=left%60;\n      d.textContent=m+\":\"+String(s).padStart(2,\"0\");\n      if(left<=60) d.style.color=\"#B91C1C\";\n      if(left<=0){ clearInterval(ti); d.textContent=\"TIME!\"; }\n    },1000);\n  }\n  update();\n</script>\n</body>\n</html>\n"
  }
}