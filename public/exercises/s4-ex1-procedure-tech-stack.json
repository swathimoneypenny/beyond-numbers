{
  "schemaVersion": "1.0",
  "id": "s4-ex1-procedure-tech-stack",
  "session": 4,
  "exercise": 1,
  "title": "Build Your Procedure Tech Stack",
  "type": "calculator",
  "summary": "Select one tool per category across six procedure/operations categories (Workflow, Documentation, Recording, Document Management, Communication, Source-Doc Capture). Team-size and client-count inputs drive the correct billing model per tool — per-user, flat, per-client, or bundled — with 2026-verified pricing. Live monthly total, annual, and per-seat cost, plus overlap and cost-driver warnings.",
  "interactive": true,
  "brand": {
    "deepPurple": "#574A9E",
    "gold": "#E6B450",
    "teal": "#4ECDC4",
    "gradient": [
      "#667EEA",
      "#764BA2"
    ],
    "font": "Calibri"
  },
  "embed": {
    "format": "html",
    "selfContained": true,
    "markup": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Session 4 · Exercise 1 — Build Your Procedure Tech Stack</title>\n<style>\n  :root{\n    --deep:#574A9E; --grad1:#667EEA; --grad2:#764BA2;\n    --gold:#E6B450; --teal:#4ECDC4; --coral:#FF6B6B;\n    --slate:#2D3748; --mute:#718096; --card:#F4F4FB; --line:#E2E0F0;\n    --green:#2F9E6B; --amber:#E6A23C;\n  }\n  *{margin:0;padding:0;box-sizing:border-box;}\n  body{font-family:'Calibri','Segoe UI',Tahoma,sans-serif;background:linear-gradient(135deg,var(--grad1) 0%,var(--grad2) 100%);min-height:100vh;padding:22px;color:var(--slate);}\n  .wrap{max-width:1500px;margin:0 auto;}\n  header{background:linear-gradient(135deg,var(--grad1) 0%,var(--grad2) 100%);color:#fff;border-radius:18px;padding:24px 30px;margin-bottom:18px;display:flex;justify-content:space-between;align-items:center;box-shadow:0 12px 34px rgba(0,0,0,.25);}\n  header .eyebrow{font-size:13px;font-weight:700;letter-spacing:4px;color:var(--gold);}\n  header h1{font-size:29px;margin:6px 0 4px;}\n  header p{opacity:.9;font-size:14.5px;max-width:820px;}\n  .timer-box{background:var(--gold);color:#5A4A12;border-radius:14px;padding:14px 24px;text-align:center;min-width:160px;}\n  .timer-box .lbl{font-size:12px;font-weight:700;letter-spacing:1px;opacity:.85;}\n  .timer-box .disp{font-size:38px;font-weight:800;line-height:1;margin:2px 0;}\n  .timer-btn{margin-top:3px;padding:5px 16px;background:#5A4A12;color:#fff;border:none;border-radius:20px;cursor:pointer;font-weight:700;font-size:13px;}\n  /* firm inputs */\n  .firmbar{background:#fff;border-radius:16px;padding:16px 22px;margin-bottom:18px;display:flex;gap:30px;align-items:center;flex-wrap:wrap;box-shadow:0 10px 30px rgba(40,30,90,.16);}\n  .firmbar .fb-lead{font-weight:700;color:var(--deep);font-size:15px;}\n  .fb-field{display:flex;align-items:center;gap:10px;}\n  .fb-field label{font-size:13px;font-weight:700;color:var(--slate);}\n  .fb-field .sub{font-size:11px;color:var(--mute);font-weight:400;display:block;}\n  .fb-field input{width:80px;border:2px solid var(--line);border-radius:9px;padding:8px 10px;font-family:inherit;font-size:17px;font-weight:700;color:var(--deep);text-align:center;}\n  .fb-field input:focus{outline:none;border-color:var(--deep);}\n  .fb-note{font-size:12px;color:var(--mute);font-style:italic;margin-left:auto;max-width:340px;}\n  .grid{display:grid;grid-template-columns:1fr 350px;gap:20px;align-items:start;}\n  .panel{background:#fff;border-radius:18px;padding:22px;box-shadow:0 10px 30px rgba(40,30,90,.16);}\n  .panel h2{color:var(--deep);font-size:19px;margin-bottom:14px;padding-bottom:10px;border-bottom:3px solid var(--gold);}\n  .cat{background:var(--card);border-radius:13px;padding:14px;margin-bottom:14px;}\n  .cat-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;}\n  .cat-title{font-weight:700;color:var(--deep);font-size:15px;}\n  .cat-desc{font-size:11.5px;color:var(--mute);margin-bottom:10px;}\n  .badge{background:var(--mute);color:#fff;padding:3px 12px;border-radius:20px;font-size:12px;font-weight:700;white-space:nowrap;}\n  .badge.set{background:var(--green);}\n  .opts{display:grid;grid-template-columns:repeat(2,1fr);gap:9px;}\n  .opt{background:#fff;border:2px solid var(--line);border-radius:10px;padding:10px 11px;cursor:pointer;transition:.15s;position:relative;}\n  .opt:hover{border-color:var(--deep);transform:translateY(-2px);}\n  .opt.sel{border-color:var(--green);background:linear-gradient(135deg,#E9F8F0 0%,#D6F0E2 100%);}\n  .opt .nm{font-weight:700;font-size:13.5px;color:var(--deep);}\n  .opt .rate{font-size:12px;color:var(--coral);font-weight:700;margin-top:2px;}\n  .opt .rate .model{color:var(--mute);font-weight:600;font-size:10.5px;}\n  .opt.inc .rate{color:var(--green);}\n  .opt .nt{font-size:10px;color:var(--mute);margin-top:3px;line-height:1.3;}\n  .opt .line{position:absolute;top:9px;right:10px;font-size:12px;font-weight:800;color:var(--deep);background:#EFEDFA;border-radius:6px;padding:2px 7px;display:none;}\n  .opt.sel .line{display:block;}\n  /* summary */\n  .side{position:sticky;top:22px;}\n  .summary{background:linear-gradient(160deg,var(--deep) 0%,#3F356F 100%);color:#fff;}\n  .summary h2{color:#fff;border-bottom-color:var(--gold);}\n  .srow{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.13);font-size:13px;}\n  .srow .v{font-weight:800;color:var(--teal);}\n  .srow .v.empty{color:#C7BEF0;font-style:italic;font-weight:400;font-size:12px;}\n  .total{margin-top:16px;padding-top:14px;border-top:3px solid var(--gold);}\n  .total .tr{display:flex;justify-content:space-between;align-items:baseline;}\n  .total .lab{font-size:16px;font-weight:700;}\n  .total .amt{font-size:32px;font-weight:800;color:var(--gold);}\n  .subline{display:flex;justify-content:space-between;font-size:12.5px;opacity:.9;margin-top:4px;}\n  .subline b{color:var(--teal);}\n  .insight{margin-top:14px;background:rgba(230,180,80,.16);border-left:4px solid var(--gold);border-radius:10px;padding:12px;}\n  .insight .it{font-size:12px;font-weight:700;color:var(--gold);margin-bottom:6px;}\n  .insight .ic2{font-size:11.5px;line-height:1.6;}\n  .btns{display:flex;gap:9px;margin-top:16px;}\n  .btn{flex:1;padding:11px;border:none;border-radius:10px;cursor:pointer;font-weight:700;font-size:13.5px;}\n  .btn.clear{background:var(--coral);color:#fff;}\n  .btn.print{background:var(--teal);color:#0E5249;}\n  .foot{text-align:center;color:rgba(255,255,255,.8);font-size:12px;margin-top:18px;}\n  @media print{\n    body{background:#fff;padding:0;}\n    header{background:var(--deep)!important;-webkit-print-color-adjust:exact;print-color-adjust:exact;}\n    .timer-box,.btns{display:none;}\n    .grid{grid-template-columns:1fr 1fr;}\n    .panel,.firmbar{box-shadow:none;border:1px solid #ddd;}\n    .summary{-webkit-print-color-adjust:exact;print-color-adjust:exact;}\n    .side{position:static;}\n  }\n  @media(max-width:1150px){.grid{grid-template-columns:1fr;}.side{position:static;}}\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <header>\n    <div>\n      <div class=\"eyebrow\">SESSION 4 · EXERCISE 1</div>\n      <h1>Build Your Procedure Tech Stack</h1>\n      <p>Select the tools to power a scalable firm. Set your team size and client count — per-user and per-client costs update live. Reference pricing (2026); verify at vendor sites.</p>\n    </div>\n    <div class=\"timer-box\">\n      <div class=\"lbl\">EXERCISE TIME</div>\n      <div class=\"disp\" id=\"timer\">12:00</div>\n      <button class=\"timer-btn\" onclick=\"startTimer()\">▶ Start</button>\n    </div>\n  </header>\n\n  <div class=\"firmbar\">\n    <span class=\"fb-lead\">Your firm:</span>\n    <div class=\"fb-field\">\n      <label>Team members<span class=\"sub\">drives per-user costs</span></label>\n      <input id=\"team\" type=\"number\" min=\"1\" value=\"5\" oninput=\"update()\">\n    </div>\n    <div class=\"fb-field\">\n      <label>Clients<span class=\"sub\">drives per-client costs</span></label>\n      <input id=\"clients\" type=\"number\" min=\"1\" value=\"20\" oninput=\"update()\">\n    </div>\n    <div class=\"fb-note\">Most of these tools bill <b>per user / month</b>. A few are flat, one (LedgerSync) is per client, and bundled tools are $0 if you already pay for Microsoft 365 or Google Workspace.</div>\n  </div>\n\n  <div class=\"grid\">\n    <div class=\"panel\">\n      <h2>Select One Tool Per Category</h2>\n      <div id=\"cats\"></div>\n    </div>\n\n    <div class=\"side\">\n      <div class=\"panel summary\">\n        <h2>Your Stack</h2>\n        <div id=\"summaryRows\"></div>\n        <div class=\"total\">\n          <div class=\"tr\"><span class=\"lab\">Monthly Total</span><span class=\"amt\" id=\"totMonthly\">$0</span></div>\n          <div class=\"subline\"><span>Annual: <b id=\"totAnnual\">$0</b></span><span>Per seat: <b id=\"perSeat\">$0</b>/mo</span></div>\n        </div>\n        <div class=\"insight\">\n          <div class=\"it\">Considerations</div>\n          <div class=\"ic2\" id=\"insight\">Select tools to see cost drivers and overlap warnings.</div>\n        </div>\n        <div class=\"btns\">\n          <button class=\"btn clear\" onclick=\"clearAll()\">Clear All</button>\n          <button class=\"btn print\" onclick=\"window.print()\">Print / Save PDF</button>\n        </div>\n      </div>\n    </div>\n  </div>\n  <div class=\"foot\">From Scorekeeper to Strategist · Session 4: Procedures &amp; Implementation · Beyond Numbers · Reference pricing as of 2026 — always confirm current rates and billing model with vendors.</div>\n</div>\n\n<script>\n  // model: \"user\" | \"flat\" | \"client\" | \"included\"\n  const CATS = [\n    { key:\"workflow\", title:\"1. Workflow / Task Management\", desc:\"Track client work, assign tasks, manage deadlines\", opts:[\n      {nm:\"Karbon\",model:\"user\",rate:59,nt:\"Team tier, annual · Business $89\"},\n      {nm:\"Canopy\",model:\"user\",rate:66,nt:\"Essentials, annual · modular\"},\n      {nm:\"Levvy\",model:\"user\",rate:59,nt:\"Starter, annual\"},\n      {nm:\"Financial Cents\",model:\"user\",rate:49,nt:\"teams, annual\"},\n    ]},\n    { key:\"docs\", title:\"2. Documentation / Playbooks\", desc:\"Create, organize, and share procedures\", opts:[\n      {nm:\"Trainual\",model:\"flat\",rate:249,nt:\"up to 10 seats · +$3–5/seat over\"},\n      {nm:\"Whale.io\",model:\"flat\",rate:99,nt:\"Team, ≤10 users · +$10/user\"},\n      {nm:\"Notion\",model:\"user\",rate:10,nt:\"Plus · free tier available\"},\n      {nm:\"OneNote (M365)\",model:\"included\",rate:0,nt:\"included with Microsoft 365\"},\n    ]},\n    { key:\"record\", title:\"3. Recording / Transcription\", desc:\"Record procedures, transcribe meetings\", opts:[\n      {nm:\"Otter.ai\",model:\"user\",rate:20,nt:\"Business, annual\"},\n      {nm:\"Zoom (Pro)\",model:\"user\",rate:17,nt:\"per host\"},\n      {nm:\"Loom\",model:\"user\",rate:18,nt:\"Business\"},\n      {nm:\"Smartphone\",model:\"included\",rate:0,nt:\"hardware you already own\"},\n    ]},\n    { key:\"dms\", title:\"4. Document Management\", desc:\"Store, search, and secure client documents\", opts:[\n      {nm:\"SmartVault\",model:\"user\",rate:45,nt:\"Accounting Pro · 2-user min\"},\n      {nm:\"Soraban\",model:\"flat\",rate:150,nt:\"custom quote · est.\"},\n      {nm:\"Google Workspace\",model:\"user\",rate:14,nt:\"Business Standard\"},\n      {nm:\"SharePoint (M365)\",model:\"included\",rate:0,nt:\"included with Microsoft 365\"},\n    ]},\n    { key:\"comm\", title:\"5. Team Communication\", desc:\"Internal messaging, channels, integrations\", opts:[\n      {nm:\"Liscio\",model:\"flat\",rate:99,nt:\"custom quote · est.\"},\n      {nm:\"Slack Pro\",model:\"user\",rate:8.75,nt:\"monthly · $7.25 annual\"},\n      {nm:\"Teams (M365)\",model:\"included\",rate:0,nt:\"included with Microsoft 365\"},\n      {nm:\"Google Chat\",model:\"included\",rate:0,nt:\"included with Google Workspace\"},\n    ]},\n    { key:\"capture\", title:\"6. Source Document Capture\", desc:\"Automate receipt / invoice collection\", opts:[\n      {nm:\"MakersHub\",model:\"flat\",rate:99,nt:\"Starter, 50 bills · Scaling $249\"},\n      {nm:\"LedgerSync\",model:\"client\",rate:10.40,min:34.90,nt:\"per client · $34.90/mo min\"},\n      {nm:\"RelayFi\",model:\"flat\",rate:30,nt:\"Grow plan · Scale $90\"},\n      {nm:\"Hubdoc (Xero)\",model:\"included\",rate:0,nt:\"free with Xero\"},\n    ]},\n  ];\n\n  const sel = {}; CATS.forEach(c=>sel[c.key]=null);\n  const team = ()=>Math.max(1, parseInt(document.getElementById(\"team\").value)||1);\n  const clients = ()=>Math.max(1, parseInt(document.getElementById(\"clients\").value)||1);\n\n  function lineCost(o){\n    if(o.model===\"user\") return o.rate*team();\n    if(o.model===\"client\") return Math.max(o.rate*clients(), o.min||0);\n    if(o.model===\"flat\") return o.rate;\n    return 0; // included\n  }\n  function rateLabel(o){\n    if(o.model===\"user\") return `$${o.rate} <span class=\"model\">/ user / mo</span>`;\n    if(o.model===\"client\") return `$${o.rate.toFixed(2)} <span class=\"model\">/ client / mo</span>`;\n    if(o.model===\"flat\") return `$${o.rate} <span class=\"model\">/ mo flat</span>`;\n    return `Included <span class=\"model\">bundled</span>`;\n  }\n  const money = n => \"$\"+Math.round(n).toLocaleString();\n\n  // render\n  const catsEl=document.getElementById(\"cats\");\n  CATS.forEach(c=>{\n    const w=document.createElement(\"div\"); w.className=\"cat\";\n    w.innerHTML=`<div class=\"cat-head\"><span class=\"cat-title\">${c.title}</span><span class=\"badge\" id=\"badge-${c.key}\">Not selected</span></div>\n      <div class=\"cat-desc\">${c.desc}</div><div class=\"opts\" id=\"opts-${c.key}\"></div>`;\n    catsEl.appendChild(w);\n    const oe=w.querySelector(`#opts-${c.key}`);\n    c.opts.forEach(o=>{\n      const d=document.createElement(\"div\");\n      d.className=\"opt\"+(o.model===\"included\"?\" inc\":\"\");\n      d.dataset.key=c.key;\n      d.innerHTML=`<div class=\"line\" id=\"line-${c.key}-${o.nm.replace(/\\W/g,'')}\"></div>\n        <div class=\"nm\">${o.nm}</div><div class=\"rate\">${rateLabel(o)}</div><div class=\"nt\">${o.nt}</div>`;\n      d.onclick=()=>pick(c.key,o,d,oe);\n      oe.appendChild(d);\n    });\n  });\n\n  function pick(key,o,el,oe){\n    oe.querySelectorAll(\".opt\").forEach(x=>x.classList.remove(\"sel\"));\n    el.classList.add(\"sel\");\n    sel[key]=o;\n    document.getElementById(\"badge-\"+key).classList.add(\"set\");\n    update();\n  }\n\n  const SUM=CATS.map(c=>[c.key,c.title.replace(/^\\d+\\.\\s/,\"\")]);\n  const sr=document.getElementById(\"summaryRows\");\n  SUM.forEach(([k,label])=>{\n    const r=document.createElement(\"div\"); r.className=\"srow\";\n    r.innerHTML=`<span>${label}</span><span class=\"v empty\" id=\"sv-${k}\">—</span>`;\n    sr.appendChild(r);\n  });\n\n  function update(){\n    let total=0;\n    CATS.forEach(c=>{\n      const o=sel[c.key];\n      const badge=document.getElementById(\"badge-\"+c.key);\n      const sv=document.getElementById(\"sv-\"+c.key);\n      // clear line chips in this category\n      c.opts.forEach(op=>{const el=document.getElementById(`line-${c.key}-${op.nm.replace(/\\W/g,'')}`); if(el) el.textContent=\"\";});\n      if(o){\n        const lc=lineCost(o);\n        total+=lc;\n        badge.textContent = o.model===\"included\" ? \"Included\" : money(lc)+\"/mo\";\n        sv.textContent = money(lc); sv.classList.remove(\"empty\");\n        const chip=document.getElementById(`line-${c.key}-${o.nm.replace(/\\W/g,'')}`); if(chip) chip.textContent=money(lc);\n      } else {\n        badge.textContent=\"Not selected\"; badge.classList.remove(\"set\");\n        sv.textContent=\"—\"; sv.classList.add(\"empty\");\n      }\n    });\n    document.getElementById(\"totMonthly\").textContent=money(total);\n    document.getElementById(\"totAnnual\").textContent=money(total*12);\n    document.getElementById(\"perSeat\").textContent=money(total/team());\n    insight(total);\n  }\n\n  function insight(total){\n    const t=[]; const s=sel;\n    const anyUser = CATS.some(c=>s[c.key] && s[c.key].model===\"user\");\n    if(anyUser) t.push(`👥 Per-user tools scale with headcount — at ${team()} seats they're your biggest cost lever. Re-check the total as you hire.`);\n    const m365 = [\"OneNote (M365)\",\"SharePoint (M365)\",\"Teams (M365)\"].filter(n=>Object.values(s).some(o=>o&&o.nm===n)).length;\n    if(m365) t.push(`🧩 You're using ${m365} Microsoft 365-bundled tool${m365>1?'s':''} at $0 — good, but only free if the firm already pays for M365.`);\n    if(s.dms && s.dms.nm===\"Google Workspace\" && s.comm && s.comm.nm===\"Google Chat\")\n      t.push(\"✅ Google Workspace already includes Chat — no separate communication cost.\");\n    if(s.dms && s.dms.nm===\"Google Workspace\" && s.docs && s.docs.nm===\"OneNote (M365)\")\n      t.push(\"⚠️ Mixing Google Workspace with a Microsoft 365 tool means paying into two ecosystems — pick a lane.\");\n    if(s.capture && s.capture.nm===\"LedgerSync\")\n      t.push(`🏦 LedgerSync bills per client, not per seat — at ${clients()} clients that's ${money(lineCost(s.capture))}/mo (min $34.90).`);\n    if(s.capture && [\"MakersHub\",\"LedgerSync\",\"RelayFi\",\"Hubdoc (Xero)\"].includes(s.capture.nm))\n      t.push(\"🔁 This capture tool also appears in the Session 3 tech-stack exercise — avoid budgeting it twice across sessions.\");\n    if(s.docs && (s.docs.nm===\"Trainual\"||s.docs.nm===\"Whale.io\"))\n      t.push(\"📘 A dedicated SOP tool is the point of this session — it replaces procedures scattered across email and drives.\");\n    if(!t.length) t.push(\"Select tools to see cost drivers and overlap warnings.\");\n    document.getElementById(\"insight\").innerHTML=t.join(\"<br><br>\");\n  }\n\n  function clearAll(){\n    CATS.forEach(c=>{sel[c.key]=null;});\n    document.querySelectorAll(\".opt\").forEach(o=>o.classList.remove(\"sel\"));\n    update();\n  }\n\n  let ti=null;\n  function startTimer(){\n    if(ti) clearInterval(ti);\n    let left=720; const d=document.getElementById(\"timer\");\n    ti=setInterval(()=>{left--;const m=Math.floor(left/60),se=left%60;d.textContent=m+\":\"+String(se).padStart(2,\"0\");if(left<=60)d.style.color=\"#B91C1C\";if(left<=0){clearInterval(ti);d.textContent=\"TIME!\";}},1000);\n  }\n  update();\n</script>\n</body>\n</html>\n"
  }
}