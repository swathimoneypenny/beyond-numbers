{
  "schemaVersion": "1.0",
  "id": "s1-ex1-four-quadrants",
  "session": 1,
  "exercise": 1,
  "title": "Four Quadrants Service Assessment",
  "type": "assessment",
  "summary": "Plot current and prospective services across the four quadrants to see where the firm sits today and where advisory growth lies. Used in-session (Tabs 1-2) with Tabs 3-5 as pre-Session-2 homework.",
  "interactive": true,
  "brand": {
    "deepPurple": "#574A9E",
    "gold": "#E6B450",
    "teal": "#4ECDC4",
    "gradient": [
      "#667EEA",
      "#764BA2"
    ],
    "font": "Calibri"
  },
  "embed": {
    "format": "html",
    "selfContained": true,
    "markup": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Four Quadrants Service Assessment</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            min-height: 100vh;\n            padding: 20px;\n        }\n        \n        .container {\n            max-width: 1400px;\n            margin: 0 auto;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 20px 60px rgba(0,0,0,0.3);\n            overflow: hidden;\n        }\n        \n        .header {\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: white;\n            padding: 30px;\n            text-align: center;\n        }\n        \n        .header h1 {\n            font-size: 32px;\n            margin-bottom: 10px;\n        }\n        \n        .header-buttons {\n            margin-top: 20px;\n        }\n        \n        .header-buttons button {\n            margin: 0 5px;\n            padding: 8px 16px;\n            background: white;\n            color: #667eea;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            font-weight: 600;\n        }\n        \n        .header-buttons button:hover {\n            background: #f0f0f0;\n        }\n        \n        .tabs {\n            display: flex;\n            background: #f8f9fa;\n            border-bottom: 2px solid #e9ecef;\n        }\n        \n        .tab {\n            flex: 1;\n            padding: 15px;\n            text-align: center;\n            cursor: pointer;\n            background: #f8f9fa;\n            border: none;\n            font-size: 16px;\n            font-weight: 600;\n            color: #6c757d;\n            transition: all 0.3s ease;\n        }\n        \n        .tab.active {\n            background: white;\n            color: #667eea;\n            border-bottom: 3px solid #667eea;\n        }\n        \n        .tab:hover {\n            background: #e9ecef;\n        }\n        \n        .tab-content {\n            display: none;\n            padding: 30px;\n            animation: fadeIn 0.5s ease;\n        }\n        \n        .tab-content.active {\n            display: block;\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(10px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        \n        .quadrant-grid {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 20px;\n            margin-bottom: 30px;\n        }\n        \n        .quadrant-box {\n            border: 2px solid #e9ecef;\n            border-radius: 10px;\n            padding: 20px;\n            background: #f8f9fa;\n        }\n        \n        .quadrant-box h3 {\n            margin-bottom: 15px;\n            color: #2d3748;\n            display: flex;\n            align-items: center;\n            gap: 10px;\n        }\n        \n        .quadrant-icon {\n            width: 30px;\n            height: 30px;\n            border-radius: 50%;\n            display: inline-flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n        }\n        \n        .operator-color { background: #6c757d; }\n        .steward-color { background: #007bff; }\n        .catalyst-color { background: #fd7e14; }\n        .strategist-color { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }\n        \n        .service-list {\n            max-height: 300px;\n            overflow-y: auto;\n        }\n        \n        .service-item {\n            display: flex;\n            align-items: center;\n            padding: 8px;\n            margin-bottom: 5px;\n            background: white;\n            border-radius: 5px;\n            transition: all 0.3s ease;\n        }\n        \n        .service-item:hover {\n            transform: translateX(5px);\n            box-shadow: 0 2px 5px rgba(0,0,0,0.1);\n        }\n        \n        .service-checkbox {\n            margin-right: 10px;\n            width: 18px;\n            height: 18px;\n            cursor: pointer;\n        }\n        \n        .service-name {\n            flex: 1;\n            font-size: 14px;\n        }\n        \n        .traffic-lights {\n            display: flex;\n            gap: 5px;\n        }\n        \n        .traffic-btn {\n            width: 25px;\n            height: 25px;\n            border-radius: 50%;\n            border: 2px solid #cbd5e0;\n            cursor: pointer;\n            transition: all 0.3s ease;\n        }\n        \n        .traffic-btn:hover {\n            transform: scale(1.1);\n        }\n        \n        .traffic-btn.green { background: #48bb78; }\n        .traffic-btn.yellow { background: #f6e05e; }\n        .traffic-btn.red { background: #fc8181; }\n        .traffic-btn.selected { \n            border-color: #2d3748; \n            border-width: 3px;\n            transform: scale(1.2); \n        }\n        \n        .assessment-table {\n            width: 100%;\n            margin-top: 30px;\n        }\n        \n        .assessment-row {\n            display: grid;\n            grid-template-columns: 2fr 1fr 0.7fr 0.8fr 1fr 0.8fr 0.5fr;\n            gap: 10px;\n            padding: 10px;\n            align-items: center;\n            background: white;\n            border: 1px solid #e9ecef;\n            margin-bottom: 5px;\n            border-radius: 5px;\n        }\n        \n        .assessment-header {\n            background: #667eea;\n            color: white;\n            font-weight: bold;\n        }\n        \n        .time-input {\n            width: 70px;\n            padding: 5px;\n            border: 1px solid #cbd5e0;\n            border-radius: 5px;\n            text-align: center;\n        }\n        \n        .action-select, .priority-select {\n            padding: 5px;\n            border: 1px solid #cbd5e0;\n            border-radius: 5px;\n            background: white;\n            font-size: 13px;\n        }\n        \n        .remove-btn {\n            background: #ff6b6b;\n            color: white;\n            border: none;\n            padding: 5px 10px;\n            border-radius: 5px;\n            cursor: pointer;\n            font-size: 18px;\n        }\n        \n        .remove-btn:hover {\n            background: #ff5252;\n        }\n        \n        .analytics-card {\n            background: white;\n            border: 2px solid #e9ecef;\n            border-radius: 10px;\n            padding: 20px;\n            margin-bottom: 20px;\n        }\n        \n        .analytics-card h3 {\n            color: #2d3748;\n            margin-bottom: 15px;\n            border-bottom: 2px solid #667eea;\n            padding-bottom: 10px;\n        }\n        \n        .stats-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n            gap: 15px;\n        }\n        \n        .stat-box {\n            padding: 15px;\n            background: #f8f9fa;\n            border-radius: 8px;\n            text-align: center;\n        }\n        \n        .stat-value {\n            font-size: 32px;\n            font-weight: bold;\n            color: #667eea;\n            margin-bottom: 5px;\n        }\n        \n        .stat-label {\n            font-size: 14px;\n            color: #6c757d;\n        }\n        \n        .export-buttons {\n            display: flex;\n            gap: 10px;\n            justify-content: center;\n            margin-top: 30px;\n            flex-wrap: wrap;\n        }\n        \n        .export-btn {\n            padding: 12px 24px;\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: white;\n            border: none;\n            border-radius: 8px;\n            font-size: 16px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n        }\n        \n        .export-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);\n        }\n        \n        .insights-list {\n            margin-top: 20px;\n        }\n        \n        .insight-item {\n            display: flex;\n            align-items: flex-start;\n            padding: 15px;\n            background: #fef5e7;\n            border-left: 4px solid #f6e05e;\n            border-radius: 5px;\n            margin-bottom: 10px;\n        }\n        \n        .insight-icon {\n            font-size: 24px;\n            margin-right: 15px;\n        }\n        \n        @media (max-width: 768px) {\n            .quadrant-grid {\n                grid-template-columns: 1fr;\n            }\n            \n            .assessment-row {\n                grid-template-columns: 1fr;\n                gap: 5px;\n            }\n            \n            .tabs {\n                flex-direction: column;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>Four Quadrants Service Assessment</h1>\n            <p>From Scorekeeper to Strategist - Advanced Analytics</p>\n            <div class=\"header-buttons\">\n                <button onclick=\"saveProgress()\">💾 Save</button>\n                <button onclick=\"loadProgress()\">📂 Load</button>\n                <button onclick=\"clearAll()\">🗑️ Clear</button>\n            </div>\n        </div>\n        \n        <div class=\"tabs\">\n            <button class=\"tab active\" onclick=\"switchTab('select')\">1. Select Services</button>\n            <button class=\"tab\" onclick=\"switchTab('assess')\">2. Assess & Rate</button>\n            <button class=\"tab\" onclick=\"switchTab('analytics')\">3. Analytics</button>\n            <button class=\"tab\" onclick=\"switchTab('insights')\">4. Insights</button>\n            <button class=\"tab\" onclick=\"switchTab('action')\">5. Action Plan</button>\n        </div>\n        \n        <div id=\"select\" class=\"tab-content active\">\n            <h2>Step 1: Select Your Current Services</h2>\n            <p style=\"margin-bottom: 20px;\">Check services you provide and rate them with traffic lights.</p>\n            \n            <div class=\"quadrant-grid\">\n                <div class=\"quadrant-box\">\n                    <h3>\n                        <span class=\"quadrant-icon operator-color\">🔧</span>\n                        OPERATOR - Do the Work\n                        <span style=\"margin-left: auto; font-size: 14px;\">\n                            <span id=\"operator-count\">0</span> selected\n                        </span>\n                    </h3>\n                    <div class=\"service-list\" id=\"operator-list\"></div>\n                </div>\n                \n                <div class=\"quadrant-box\">\n                    <h3>\n                        <span class=\"quadrant-icon steward-color\">🛡️</span>\n                        STEWARD - Protect Assets\n                        <span style=\"margin-left: auto; font-size: 14px;\">\n                            <span id=\"steward-count\">0</span> selected\n                        </span>\n                    </h3>\n                    <div class=\"service-list\" id=\"steward-list\"></div>\n                </div>\n                \n                <div class=\"quadrant-box\">\n                    <h3>\n                        <span class=\"quadrant-icon catalyst-color\">💫</span>\n                        CATALYST - Transform\n                        <span style=\"margin-left: auto; font-size: 14px;\">\n                            <span id=\"catalyst-count\">0</span> selected\n                        </span>\n                    </h3>\n                    <div class=\"service-list\" id=\"catalyst-list\"></div>\n                </div>\n                \n                <div class=\"quadrant-box\">\n                    <h3>\n                        <span class=\"quadrant-icon strategist-color\">🎯</span>\n                        STRATEGIST - Plan & Advise\n                        <span style=\"margin-left: auto; font-size: 14px;\">\n                            <span id=\"strategist-count\">0</span> selected\n                        </span>\n                    </h3>\n                    <div class=\"service-list\" id=\"strategist-list\"></div>\n                </div>\n            </div>\n            \n            <div class=\"export-buttons\">\n                <button class=\"export-btn\" onclick=\"switchTab('assess')\">Continue to Assessment →</button>\n            </div>\n        </div>\n        \n        <div id=\"assess\" class=\"tab-content\">\n            <h2>Step 2: Detailed Assessment</h2>\n            <p style=\"margin-bottom: 20px;\">Add time allocation and action needed for each service.</p>\n            \n            <div class=\"assessment-table\">\n                <div class=\"assessment-row assessment-header\">\n                    <div>Service</div>\n                    <div>Quadrant</div>\n                    <div>% Time</div>\n                    <div>Rating</div>\n                    <div>Action</div>\n                    <div>Priority</div>\n                    <div>×</div>\n                </div>\n                <div id=\"assessment-list\"></div>\n            </div>\n            \n            <div class=\"export-buttons\">\n                <button class=\"export-btn\" onclick=\"switchTab('analytics')\">View Analytics →</button>\n            </div>\n        </div>\n        \n        <div id=\"analytics\" class=\"tab-content\">\n            <h2>Analytics Dashboard</h2>\n            \n            <div class=\"analytics-card\">\n                <h3>📊 Portfolio Summary</h3>\n                <div class=\"stats-grid\" id=\"summary-stats\"></div>\n            </div>\n            \n            <div class=\"analytics-card\">\n                <h3>⏰ Time Distribution</h3>\n                <div class=\"stats-grid\" id=\"time-distribution\"></div>\n            </div>\n            \n            <div class=\"analytics-card\">\n                <h3>🎯 Traffic Light Analysis</h3>\n                <div class=\"stats-grid\" id=\"traffic-analysis\"></div>\n            </div>\n            \n            <div class=\"export-buttons\">\n                <button class=\"export-btn\" onclick=\"switchTab('insights')\">View Insights →</button>\n            </div>\n        </div>\n        \n        <div id=\"insights\" class=\"tab-content\">\n            <h2>Strategic Insights</h2>\n            \n            <div class=\"analytics-card\">\n                <h3>💡 Key Recommendations</h3>\n                <div class=\"insights-list\" id=\"insights-list\"></div>\n            </div>\n            \n            <div class=\"analytics-card\">\n                <h3>💰 ROI Projection</h3>\n                <div class=\"stats-grid\">\n                    <div class=\"stat-box\">\n                        <div class=\"stat-value\" id=\"hours-to-save\">0</div>\n                        <div class=\"stat-label\">Hours to Reclaim/Week</div>\n                    </div>\n                    <div class=\"stat-box\">\n                        <div class=\"stat-value\" id=\"annual-value\">$0</div>\n                        <div class=\"stat-label\">Annual Value (@ $250/hr)</div>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"export-buttons\">\n                <button class=\"export-btn\" onclick=\"switchTab('action')\">Create Action Plan →</button>\n            </div>\n        </div>\n        \n        <div id=\"action\" class=\"tab-content\">\n            <h2>Your Action Plan</h2>\n            \n            <div class=\"analytics-card\">\n                <h3>🚨 Immediate Actions (Next 30 Days)</h3>\n                <div id=\"immediate-actions\"></div>\n            </div>\n            \n            <div class=\"analytics-card\">\n                <h3>📅 90-Day Transformation Plan</h3>\n                <div id=\"transformation-plan\"></div>\n            </div>\n            \n            <div class=\"export-buttons\">\n                <button class=\"export-btn\" onclick=\"exportReport()\">📄 Export Full Report</button>\n                <button class=\"export-btn\" onclick=\"exportCSV()\">📊 Export to CSV</button>\n                <button class=\"export-btn\" onclick=\"printReport()\">🖨️ Print</button>\n            </div>\n        </div>\n    </div>\n    \n    <script>\n        const services = {\n            operator: [\n                'Manual transaction entry', 'Bank reconciliations', 'Credit card reconciliations',\n                'Accounts payable data entry', 'Receipt scanning', 'Expense report processing',\n                'Check printing', 'Sales tax filing (simple)', '1099 preparation', 'W-2 processing',\n                'Simple payroll processing', 'Invoice generation', 'Monthly P&L statements'\n            ],\n            steward: [\n                'Tax return prep (1040)', 'Tax return prep (1120)', 'Tax return prep (1065)',\n                'Tax extension filing', 'Estimated tax calculations', 'IRS correspondence',\n                'Financial statement prep', 'Audit support', 'Month-end closing', \n                'Year-end closing', 'Payroll review', 'Sales tax review', 'Depreciation calculations'\n            ],\n            catalyst: [\n                'Workflow automation design', 'Software implementation', 'Process reengineering',\n                'Digital transformation', 'Cloud migration', 'Efficiency analysis',\n                'Cost reduction initiatives', 'Pricing strategy', 'Business expansion planning',\n                'ERP selection', 'CRM implementation', 'Dashboard creation'\n            ],\n            strategist: [\n                'CFO services (fractional)', 'Strategic planning', 'Business model consulting',\n                'Cash flow forecasting', 'Financial modeling', 'Budget development',\n                'Business plan writing', 'Investor pitch prep', 'Valuation services',\n                'Exit strategy planning', 'CEO advisory', 'Executive coaching', 'Crisis management'\n            ]\n        };\n        \n        let selectedServices = {};\n        \n        function initializeTool() {\n            Object.keys(services).forEach(quadrant => {\n                const listElement = document.getElementById(`${quadrant}-list`);\n                services[quadrant].forEach((service, index) => {\n                    const div = document.createElement('div');\n                    div.className = 'service-item';\n                    const id = `${quadrant}-${index}`;\n                    \n                    div.innerHTML = `\n                        <input type=\"checkbox\" class=\"service-checkbox\" id=\"${id}\" \n                               onchange=\"toggleService('${quadrant}', ${index}, this.checked)\">\n                        <span class=\"service-name\">${service}</span>\n                        <div class=\"traffic-lights\">\n                            <button class=\"traffic-btn green\" \n                                    onclick=\"setTraffic('${id}', 'green', event)\"></button>\n                            <button class=\"traffic-btn yellow\" \n                                    onclick=\"setTraffic('${id}', 'yellow', event)\"></button>\n                            <button class=\"traffic-btn red\" \n                                    onclick=\"setTraffic('${id}', 'red', event)\"></button>\n                        </div>\n                    `;\n                    listElement.appendChild(div);\n                });\n            });\n        }\n        \n        function toggleService(quadrant, index, checked) {\n            const key = `${quadrant}-${index}`;\n            if (checked) {\n                selectedServices[key] = {\n                    service: services[quadrant][index],\n                    quadrant: quadrant,\n                    traffic: null,\n                    time: 0,\n                    action: 'Keep',\n                    priority: 'Medium'\n                };\n            } else {\n                delete selectedServices[key];\n                const buttons = document.getElementById(key).parentElement.querySelectorAll('.traffic-btn');\n                buttons.forEach(btn => btn.classList.remove('selected'));\n            }\n            updateCounts();\n            updateAssessment();\n            updateAnalytics();\n        }\n        \n        function setTraffic(id, color, event) {\n            event.stopPropagation();\n            if (!selectedServices[id]) return;\n            \n            const parent = document.getElementById(id).parentElement;\n            const buttons = parent.querySelectorAll('.traffic-btn');\n            buttons.forEach(btn => btn.classList.remove('selected'));\n            event.target.classList.add('selected');\n            \n            selectedServices[id].traffic = color;\n            updateAssessment();\n            updateAnalytics();\n        }\n        \n        function updateCounts() {\n            ['operator', 'steward', 'catalyst', 'strategist'].forEach(q => {\n                const count = Object.values(selectedServices).filter(s => s.quadrant === q).length;\n                document.getElementById(`${q}-count`).textContent = count;\n            });\n        }\n        \n        function updateAssessment() {\n            const list = document.getElementById('assessment-list');\n            list.innerHTML = '';\n            \n            Object.entries(selectedServices).forEach(([key, data]) => {\n                const row = document.createElement('div');\n                row.className = 'assessment-row';\n                \n                const trafficEmoji = data.traffic === 'green' ? '🟢' : \n                                   data.traffic === 'yellow' ? '🟡' : \n                                   data.traffic === 'red' ? '🔴' : '⚪';\n                \n                row.innerHTML = `\n                    <div>${data.service}</div>\n                    <div style=\"text-transform: uppercase; font-size: 12px;\">${data.quadrant}</div>\n                    <div><input type=\"number\" class=\"time-input\" value=\"${data.time}\" \n                                onchange=\"updateTime('${key}', this.value)\" min=\"0\" max=\"100\"></div>\n                    <div style=\"font-size: 20px;\">${trafficEmoji}</div>\n                    <div>\n                        <select class=\"action-select\" onchange=\"updateAction('${key}', this.value)\">\n                            <option>Keep</option>\n                            <option>Outsource</option>\n                            <option>Automate</option>\n                            <option>Eliminate</option>\n                        </select>\n                    </div>\n                    <div>\n                        <select class=\"priority-select\" onchange=\"updatePriority('${key}', this.value)\">\n                            <option>Low</option>\n                            <option selected>Medium</option>\n                            <option>High</option>\n                        </select>\n                    </div>\n                    <div><button class=\"remove-btn\" onclick=\"removeService('${key}')\">×</button></div>\n                `;\n                list.appendChild(row);\n            });\n        }\n        \n        function updateTime(key, value) {\n            if (selectedServices[key]) {\n                selectedServices[key].time = parseInt(value) || 0;\n                updateAnalytics();\n            }\n        }\n        \n        function updateAction(key, value) {\n            if (selectedServices[key]) {\n                selectedServices[key].action = value;\n                updateAnalytics();\n            }\n        }\n        \n        function updatePriority(key, value) {\n            if (selectedServices[key]) {\n                selectedServices[key].priority = value;\n                updateAnalytics();\n            }\n        }\n        \n        function removeService(key) {\n            delete selectedServices[key];\n            document.getElementById(key).checked = false;\n            updateCounts();\n            updateAssessment();\n            updateAnalytics();\n        }\n        \n        function updateAnalytics() {\n            updateSummaryStats();\n            updateTimeDistribution();\n            updateTrafficAnalysis();\n            updateInsights();\n            updateActionPlan();\n        }\n        \n        function updateSummaryStats() {\n            const elem = document.getElementById('summary-stats');\n            if (!elem) return;\n            \n            const total = Object.keys(selectedServices).length;\n            const quadrants = {};\n            Object.values(selectedServices).forEach(s => {\n                quadrants[s.quadrant] = (quadrants[s.quadrant] || 0) + 1;\n            });\n            \n            elem.innerHTML = `\n                <div class=\"stat-box\">\n                    <div class=\"stat-value\">${total}</div>\n                    <div class=\"stat-label\">Total Services</div>\n                </div>\n                <div class=\"stat-box\">\n                    <div class=\"stat-value\">${quadrants.operator || 0}</div>\n                    <div class=\"stat-label\">Operator</div>\n                </div>\n                <div class=\"stat-box\">\n                    <div class=\"stat-value\">${quadrants.steward || 0}</div>\n                    <div class=\"stat-label\">Steward</div>\n                </div>\n                <div class=\"stat-box\">\n                    <div class=\"stat-value\">${quadrants.catalyst || 0}</div>\n                    <div class=\"stat-label\">Catalyst</div>\n                </div>\n                <div class=\"stat-box\">\n                    <div class=\"stat-value\">${quadrants.strategist || 0}</div>\n                    <div class=\"stat-label\">Strategist</div>\n                </div>\n            `;\n        }\n        \n        function updateTimeDistribution() {\n            const elem = document.getElementById('time-distribution');\n            if (!elem) return;\n            \n            const timeByQuadrant = {};\n            Object.values(selectedServices).forEach(s => {\n                timeByQuadrant[s.quadrant] = (timeByQuadrant[s.quadrant] || 0) + (s.time || 0);\n            });\n            \n            elem.innerHTML = Object.entries(timeByQuadrant).map(([q, time]) => `\n                <div class=\"stat-box\">\n                    <div class=\"stat-value\">${time}%</div>\n                    <div class=\"stat-label\">${q.toUpperCase()}</div>\n                </div>\n            `).join('');\n        }\n        \n        function updateTrafficAnalysis() {\n            const elem = document.getElementById('traffic-analysis');\n            if (!elem) return;\n            \n            const traffic = { green: 0, yellow: 0, red: 0 };\n            Object.values(selectedServices).forEach(s => {\n                if (s.traffic) traffic[s.traffic]++;\n            });\n            \n            elem.innerHTML = `\n                <div class=\"stat-box\">\n                    <div class=\"stat-value\" style=\"color: #48bb78;\">${traffic.green}</div>\n                    <div class=\"stat-label\">🟢 Love It</div>\n                </div>\n                <div class=\"stat-box\">\n                    <div class=\"stat-value\" style=\"color: #f6e05e;\">${traffic.yellow}</div>\n                    <div class=\"stat-label\">🟡 It's OK</div>\n                </div>\n                <div class=\"stat-box\">\n                    <div class=\"stat-value\" style=\"color: #fc8181;\">${traffic.red}</div>\n                    <div class=\"stat-label\">🔴 Eliminate</div>\n                </div>\n            `;\n        }\n        \n        function updateInsights() {\n            const list = document.getElementById('insights-list');\n            if (!list) return;\n            \n            const insights = [];\n            const traffic = { red: 0, yellow: 0, green: 0 };\n            const quadrantCounts = {};\n            const redItems = [];\n            \n            Object.values(selectedServices).forEach(s => {\n                if (s.traffic) traffic[s.traffic]++;\n                quadrantCounts[s.quadrant] = (quadrantCounts[s.quadrant] || 0) + 1;\n                if (s.traffic === 'red') redItems.push(s);\n            });\n            \n            if (traffic.red > 3) {\n                insights.push({\n                    icon: '🚨',\n                    text: `You have ${traffic.red} RED items. Eliminating these could free up ${traffic.red * 5} hours per week.`\n                });\n            }\n            \n            if ((quadrantCounts.operator || 0) > (quadrantCounts.strategist || 0) * 2) {\n                insights.push({\n                    icon: '⚠️',\n                    text: 'You\\'re spending too much time on low-value operational tasks. Consider aggressive outsourcing.'\n                });\n            }\n            \n            if ((quadrantCounts.strategist || 0) < 3) {\n                insights.push({\n                    icon: '💡',\n                    text: 'Low strategic activity detected. Focus on building high-value advisory services.'\n                });\n            }\n            \n            if (traffic.green > traffic.red * 2) {\n                insights.push({\n                    icon: '✨',\n                    text: 'Strong alignment! You enjoy most of your work. Now optimize for profitability.'\n                });\n            }\n            \n            list.innerHTML = insights.map(i => `\n                <div class=\"insight-item\">\n                    <span class=\"insight-icon\">${i.icon}</span>\n                    <span>${i.text}</span>\n                </div>\n            `).join('') || '<p style=\"color: #999;\">Select and rate more services to see insights.</p>';\n            \n            const hoursToSave = redItems.reduce((sum, s) => sum + (s.time * 0.4), 0);\n            document.getElementById('hours-to-save').textContent = Math.round(hoursToSave);\n            document.getElementById('annual-value').textContent = '$' + (hoursToSave * 50 * 250).toLocaleString();\n        }\n        \n        function updateActionPlan() {\n            const immediate = document.getElementById('immediate-actions');\n            const plan = document.getElementById('transformation-plan');\n            if (!immediate || !plan) return;\n            \n            const redItems = Object.values(selectedServices).filter(s => s.traffic === 'red');\n            const yellowItems = Object.values(selectedServices).filter(s => s.traffic === 'yellow');\n            const greenStrategic = Object.values(selectedServices).filter(s => \n                s.traffic === 'green' && s.quadrant === 'strategist'\n            );\n            \n            immediate.innerHTML = redItems.slice(0, 3).map((s, i) => `\n                <p style=\"padding: 10px; background: #ffebee; border-radius: 5px; margin-bottom: 10px;\">\n                    <strong>Day ${(i+1)*10}:</strong> Eliminate or outsource \"${s.service}\"\n                </p>\n            `).join('') || '<p style=\"color: #999;\">No immediate actions identified.</p>';\n            \n            plan.innerHTML = `\n                <p style=\"margin-bottom: 15px;\"><strong>Month 1:</strong> Eliminate ${redItems.length} red items</p>\n                <p style=\"margin-bottom: 15px;\"><strong>Month 2:</strong> Automate/outsource ${yellowItems.length} yellow items</p>\n                <p><strong>Month 3:</strong> Expand ${greenStrategic.length} strategic services</p>\n            `;\n        }\n        \n        function switchTab(tabName) {\n            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));\n            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));\n            \n            event.target.classList.add('active');\n            document.getElementById(tabName).classList.add('active');\n            \n            if (['analytics', 'insights', 'action'].includes(tabName)) {\n                updateAnalytics();\n            }\n        }\n        \n        function saveProgress() {\n            localStorage.setItem('quadrantData', JSON.stringify(selectedServices));\n            alert('Progress saved!');\n        }\n        \n        function loadProgress() {\n            const saved = localStorage.getItem('quadrantData');\n            if (saved) {\n                selectedServices = JSON.parse(saved);\n                Object.keys(selectedServices).forEach(key => {\n                    const cb = document.getElementById(key);\n                    if (cb) {\n                        cb.checked = true;\n                        if (selectedServices[key].traffic) {\n                            const color = selectedServices[key].traffic;\n                            const parent = cb.parentElement;\n                            const btn = parent.querySelector(`.traffic-btn.${color}`);\n                            if (btn) btn.classList.add('selected');\n                        }\n                    }\n                });\n                updateCounts();\n                updateAssessment();\n                updateAnalytics();\n                alert('Progress loaded!');\n            } else {\n                alert('No saved data found.');\n            }\n        }\n        \n        function clearAll() {\n            if (confirm('Clear all data?')) {\n                selectedServices = {};\n                document.querySelectorAll('.service-checkbox').forEach(cb => cb.checked = false);\n                document.querySelectorAll('.traffic-btn').forEach(btn => btn.classList.remove('selected'));\n                updateCounts();\n                updateAssessment();\n                updateAnalytics();\n            }\n        }\n        \n        function exportReport() {\n            let report = '=== FOUR QUADRANTS ASSESSMENT REPORT ===\\n\\n';\n            report += `Date: ${new Date().toLocaleDateString()}\\n\\n`;\n            report += `Total Services: ${Object.keys(selectedServices).length}\\n\\n`;\n            \n            const traffic = { red: 0, yellow: 0, green: 0 };\n            Object.values(selectedServices).forEach(s => {\n                if (s.traffic) traffic[s.traffic]++;\n            });\n            \n            report += '--- TRAFFIC LIGHT SUMMARY ---\\n';\n            report += `🟢 Green (Love): ${traffic.green}\\n`;\n            report += `🟡 Yellow (OK): ${traffic.yellow}\\n`;\n            report += `🔴 Red (Eliminate): ${traffic.red}\\n\\n`;\n            \n            report += '--- DETAILED SERVICES ---\\n';\n            Object.values(selectedServices).forEach(s => {\n                report += `\\n${s.service}\\n`;\n                report += `  Quadrant: ${s.quadrant}\\n`;\n                report += `  Rating: ${s.traffic || 'Not rated'}\\n`;\n                report += `  Time: ${s.time}%\\n`;\n                report += `  Action: ${s.action}\\n`;\n            });\n            \n            const blob = new Blob([report], { type: 'text/plain' });\n            const url = URL.createObjectURL(blob);\n            const a = document.createElement('a');\n            a.href = url;\n            a.download = 'quadrant_assessment.txt';\n            a.click();\n            URL.revokeObjectURL(url);\n        }\n        \n        function exportCSV() {\n            let csv = 'Service,Quadrant,Rating,Time %,Action,Priority\\n';\n            Object.values(selectedServices).forEach(s => {\n                csv += `\"${s.service}\",\"${s.quadrant}\",\"${s.traffic || 'None'}\",${s.time},\"${s.action}\",\"${s.priority}\"\\n`;\n            });\n            \n            const blob = new Blob([csv], { type: 'text/csv' });\n            const url = URL.createObjectURL(blob);\n            const a = document.createElement('a');\n            a.href = url;\n            a.download = 'quadrant_assessment.csv';\n            a.click();\n            URL.revokeObjectURL(url);\n        }\n        \n        function printReport() {\n            window.print();\n        }\n        \n        window.onload = initializeTool;\n    </script>\n</body>\n</html>"
  }
}