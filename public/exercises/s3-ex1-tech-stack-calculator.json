{
  "schemaVersion": "1.0",
  "id": "s3-ex1-tech-stack-calculator",
  "session": 3,
  "exercise": 1,
  "title": "Tech Stack Cost Calculator",
  "type": "calculator",
  "summary": "Build an advisory tech stack for the Regional Distribution Co. case across seven app categories with 2026-verified pricing; live total and benchmark.",
  "interactive": true,
  "brand": {
    "deepPurple": "#574A9E",
    "gold": "#E6B450",
    "teal": "#4ECDC4",
    "gradient": [
      "#667EEA",
      "#764BA2"
    ],
    "font": "Calibri"
  },
  "embed": {
    "format": "html",
    "selfContained": true,
    "markup": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Exercise 1 — Build Your Advisory Tech Stack | Session 3</title>\n<style>\n  :root{\n    --deep:#574A9E; --grad1:#667EEA; --grad2:#764BA2;\n    --gold:#E6B450; --teal:#4ECDC4; --coral:#FF6B6B;\n    --slate:#2D3748; --mute:#718096; --card:#F4F4FB; --line:#E2E0F0;\n    --green:#2F9E6B; --amber:#E6A23C; --red:#E05C5C;\n  }\n  *{margin:0;padding:0;box-sizing:border-box;}\n  body{font-family:'Calibri','Segoe UI',Tahoma,sans-serif;background:linear-gradient(135deg,var(--grad1) 0%,var(--grad2) 100%);min-height:100vh;padding:22px;color:var(--slate);}\n  .wrap{max-width:1480px;margin:0 auto;}\n  header{background:linear-gradient(135deg,var(--grad1) 0%,var(--grad2) 100%);color:#fff;border-radius:18px;padding:26px 30px;margin-bottom:22px;display:flex;justify-content:space-between;align-items:center;box-shadow:0 12px 34px rgba(0,0,0,.25);}\n  header .eyebrow{font-size:13px;font-weight:700;letter-spacing:4px;color:var(--gold);}\n  header h1{font-size:30px;margin:6px 0 4px;}\n  header p{opacity:.9;font-size:15px;}\n  .timer-box{background:var(--gold);color:#5A4A12;border-radius:14px;padding:16px 26px;text-align:center;min-width:170px;}\n  .timer-box .lbl{font-size:12px;font-weight:700;letter-spacing:1px;opacity:.85;}\n  .timer-box .disp{font-size:42px;font-weight:800;line-height:1;margin:2px 0;}\n  .timer-btn{margin-top:4px;padding:5px 16px;background:#5A4A12;color:#fff;border:none;border-radius:20px;cursor:pointer;font-weight:700;font-size:13px;}\n  .grid{display:grid;grid-template-columns:330px 1fr 330px;gap:22px;}\n  .panel{background:#fff;border-radius:18px;padding:22px;box-shadow:0 10px 30px rgba(40,30,90,.16);}\n  .panel h2{color:var(--deep);font-size:19px;margin-bottom:16px;padding-bottom:10px;border-bottom:3px solid var(--gold);}\n  /* profile */\n  .profile{background:var(--card);}\n  .pitem{display:flex;gap:11px;align-items:flex-start;background:#fff;border-radius:11px;padding:11px 13px;margin-bottom:9px;border-left:4px solid var(--deep);}\n  .pitem .ic{width:34px;height:34px;border-radius:9px;background:var(--deep);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;flex-shrink:0;}\n  .pitem .tx{font-size:13.5px;}\n  .pitem .tx strong{display:block;color:var(--deep);font-size:13.5px;}\n  .tipbox{margin-top:14px;background:#EAF8F6;border-left:4px solid var(--teal);border-radius:10px;padding:13px;}\n  .tipbox .th{color:#2F8276;font-weight:700;font-size:13px;margin-bottom:6px;}\n  .tipbox ul{list-style:none;font-size:12.5px;line-height:1.7;color:var(--slate);}\n  .tipbox li::before{content:\"›\";color:var(--teal);font-weight:800;margin-right:7px;}\n  /* categories */\n  .cat{background:var(--card);border-radius:13px;padding:14px;margin-bottom:14px;}\n  .cat-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:11px;}\n  .cat-title{font-weight:700;color:var(--deep);font-size:15px;}\n  .cat-title .sub{font-weight:400;color:var(--mute);font-size:12px;}\n  .badge{background:var(--mute);color:#fff;padding:3px 12px;border-radius:20px;font-size:12px;font-weight:700;}\n  .badge.set{background:var(--green);}\n  .opts{display:grid;grid-template-columns:repeat(2,1fr);gap:9px;}\n  .opt{background:#fff;border:2px solid var(--line);border-radius:10px;padding:11px;cursor:pointer;transition:.15s;text-align:center;}\n  .opt:hover{border-color:var(--deep);transform:translateY(-2px);}\n  .opt.sel{border-color:var(--green);background:linear-gradient(135deg,#E9F8F0 0%,#D6F0E2 100%);}\n  .opt .nm{font-weight:700;font-size:13.5px;color:var(--deep);}\n  .opt .pr{font-size:13px;color:var(--coral);font-weight:700;margin-top:2px;}\n  .opt .nt{font-size:10.5px;color:var(--mute);margin-top:3px;line-height:1.3;}\n  .opt.ai .pr{color:var(--deep);}\n  /* summary */\n  .summary{background:linear-gradient(160deg,var(--deep) 0%,#3F356F 100%);color:#fff;}\n  .summary h2{color:#fff;border-bottom-color:var(--gold);}\n  .srow{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.13);font-size:13.5px;}\n  .srow .v{font-weight:800;color:var(--teal);}\n  .srow .v.empty{color:#C7BEF0;font-style:italic;font-weight:400;font-size:12.5px;}\n  .total{margin-top:18px;padding-top:16px;border-top:3px solid var(--gold);}\n  .total .tr{display:flex;justify-content:space-between;align-items:baseline;}\n  .total .lab{font-size:17px;font-weight:700;}\n  .total .amt{font-size:34px;font-weight:800;color:var(--gold);}\n  .annual{text-align:right;font-size:13px;opacity:.85;margin-top:3px;}\n  .bench{margin-top:18px;background:rgba(255,255,255,.08);border-radius:12px;padding:15px;}\n  .bench .bt{font-size:12.5px;opacity:.85;margin-bottom:9px;}\n  .bar{height:26px;background:rgba(255,255,255,.13);border-radius:13px;overflow:hidden;}\n  .fill{height:100%;width:0;background:linear-gradient(90deg,var(--teal) 0%,var(--gold) 70%,var(--coral) 100%);transition:width .4s;display:flex;align-items:center;justify-content:flex-end;padding-right:9px;font-size:11px;font-weight:800;color:#3F356F;}\n  .blabels{display:flex;justify-content:space-between;margin-top:6px;font-size:10.5px;opacity:.75;}\n  .insight{margin-top:16px;background:rgba(230,180,80,.16);border-left:4px solid var(--gold);border-radius:10px;padding:13px;}\n  .insight .it{font-size:12.5px;font-weight:700;color:var(--gold);margin-bottom:6px;}\n  .insight .ic2{font-size:12px;line-height:1.6;}\n  .btns{display:flex;gap:9px;margin-top:18px;}\n  .btn{flex:1;padding:11px;border:none;border-radius:10px;cursor:pointer;font-weight:700;font-size:13.5px;}\n  .btn.clear{background:var(--coral);color:#fff;}\n  .btn.print{background:var(--teal);color:#0E5249;}\n  .foot{text-align:center;color:rgba(255,255,255,.8);font-size:12.5px;margin-top:20px;}\n  @media print{\n    body{background:#fff;padding:0;}\n    header{background:var(--deep)!important;-webkit-print-color-adjust:exact;print-color-adjust:exact;}\n    .timer-box,.btns{display:none;}\n    .grid{grid-template-columns:1fr 1fr;}\n    .panel{box-shadow:none;border:1px solid #ddd;}\n    .summary{-webkit-print-color-adjust:exact;print-color-adjust:exact;}\n  }\n  @media(max-width:1180px){.grid{grid-template-columns:1fr;}}\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <header>\n    <div>\n      <div class=\"eyebrow\">SESSION 3 · EXERCISE 1</div>\n      <h1>Build Your Advisory Tech Stack</h1>\n      <p>Cost out a complete, scalable cloud stack — pick one app per category. Reference pricing (2026); verify at vendor sites.</p>\n    </div>\n    <div class=\"timer-box\">\n      <div class=\"lbl\">EXERCISE TIME</div>\n      <div class=\"disp\" id=\"timer\">12:00</div>\n      <button class=\"timer-btn\" onclick=\"startTimer()\">▶ Start</button>\n    </div>\n  </header>\n\n  <div class=\"grid\">\n    <!-- PROFILE -->\n    <div class=\"panel profile\">\n      <h2>Client Profile</h2>\n      <div class=\"pitem\"><div class=\"ic\">RD</div><div class=\"tx\"><strong>Regional Distribution Co.</strong>Wholesale/distribution, moving off QuickBooks Desktop</div></div>\n      <div class=\"pitem\"><div class=\"ic\">30</div><div class=\"tx\"><strong>30 employees</strong>20 onsite · 10 remote/traveling</div></div>\n      <div class=\"pitem\"><div class=\"ic\">📦</div><div class=\"tx\"><strong>Inventory & POs</strong>Sales quotes, PO generation, stock levels</div></div>\n      <div class=\"pitem\"><div class=\"ic\">⏱</div><div class=\"tx\"><strong>Time & expenses</strong>Time for all 30; travel expense capture for 10</div></div>\n      <div class=\"pitem\"><div class=\"ic\">📊</div><div class=\"tx\"><strong>Reporting</strong>KPIs, cash flow, management reports</div></div>\n      <div class=\"tipbox\">\n        <div class=\"th\">Selection tips</div>\n        <ul>\n          <li>Favor native integration to your GL</li>\n          <li>Watch for overlapping/bundled features</li>\n          <li>Factor per-employee costs at 30 staff</li>\n          <li>Mobile-friendly matters for the 10 travelers</li>\n        </ul>\n      </div>\n    </div>\n\n    <!-- SELECTION -->\n    <div class=\"panel\">\n      <h2>Select Your Apps</h2>\n      <div id=\"cats\"></div>\n    </div>\n\n    <!-- SUMMARY -->\n    <div class=\"panel summary\">\n      <h2>Your Stack Summary</h2>\n      <div id=\"summaryRows\"></div>\n      <div class=\"total\">\n        <div class=\"tr\"><span class=\"lab\">Monthly Total</span><span class=\"amt\" id=\"totMonthly\">$0</span></div>\n        <div class=\"annual\">Annual: <strong id=\"totAnnual\">$0</strong></div>\n      </div>\n      <div class=\"bench\">\n        <div class=\"bt\">Cost vs. benchmark for a 30-employee client</div>\n        <div class=\"bar\"><div class=\"fill\" id=\"fill\"></div></div>\n        <div class=\"blabels\"><span>$0</span><span>$1,000</span><span>$1,400</span><span>$1,800+</span></div>\n      </div>\n      <div class=\"insight\">\n        <div class=\"it\">Considerations</div>\n        <div class=\"ic2\" id=\"insight\">Select apps to see integration tips and cost-saving opportunities.</div>\n      </div>\n      <div class=\"btns\">\n        <button class=\"btn clear\" onclick=\"clearAll()\">Clear All</button>\n        <button class=\"btn print\" onclick=\"window.print()\">Print / Save PDF</button>\n      </div>\n    </div>\n  </div>\n  <div class=\"foot\">From Scorekeeper to Strategist · Session 3: Technology &amp; AI · Beyond Numbers · Reference pricing as of 2026 — always confirm current rates with vendors.</div>\n</div>\n\n<script>\n  // ---- data (2026 reference pricing) ----\n  const CATS = [\n    { key:\"gl\", title:\"General Ledger\", sub:\"\", opts:[\n      {nm:\"QBO Plus\",cost:115,nt:\"5 users · most popular\"},\n      {nm:\"QBO Advanced\",cost:275,nt:\"25 users · automation\"},\n      {nm:\"Xero Established\",cost:80,nt:\"unlimited users\"},\n      {nm:\"Sage Intacct\",cost:500,nt:\"mid-market · est.\"},\n    ]},\n    { key:\"inventory\", title:\"Inventory\", sub:\"\", opts:[\n      {nm:\"Katana\",cost:399,nt:\"MRP · QBO/Xero sync\"},\n      {nm:\"Cin7 Core\",cost:349,nt:\"multi-channel · EDI\"},\n      {nm:\"inFlow\",cost:219,nt:\"light mfg/distribution\"},\n      {nm:\"Zoho Inventory\",cost:99,nt:\"budget · Zoho stack\"},\n    ]},\n    { key:\"payroll\", title:\"Payroll\", sub:\"(30 employees)\", opts:[\n      {nm:\"Gusto Simple\",cost:229,nt:\"$49 + $6×30\"},\n      {nm:\"Gusto Plus\",cost:440,nt:\"$80 + $12×30 · HR\"},\n      {nm:\"QuickBooks Payroll\",cost:195,nt:\"$45 + $5×30 · Core\"},\n      {nm:\"ADP Run\",cost:300,nt:\"enterprise · est.\"},\n    ]},\n    { key:\"time\", title:\"Time Tracking\", sub:\"(30 staff)\", opts:[\n      {nm:\"QuickBooks Time\",cost:260,nt:\"$20 + $8×30 · QBO native\"},\n      {nm:\"Homebase\",cost:100,nt:\"scheduling + time\"},\n      {nm:\"Timesheets.com\",cost:150,nt:\"~$5 × 30\"},\n      {nm:\"Clockify\",cost:0,nt:\"free tier\"},\n    ]},\n    { key:\"expenses\", title:\"Expenses / AP\", sub:\"(10 travelers)\", opts:[\n      {nm:\"Ramp\",cost:0,nt:\"free · cards + expense\"},\n      {nm:\"Expensify\",cost:90,nt:\"~$9 × 10 travelers\"},\n      {nm:\"Gusto Expenses\",cost:0,nt:\"included w/ Plus+\"},\n      {nm:\"Zoho Expense\",cost:50,nt:\"~$5 × 10\"},\n    ]},\n    { key:\"reporting\", title:\"Reporting / FP&A\", sub:\"\", opts:[\n      {nm:\"Fathom\",cost:59,nt:\"financial analysis\"},\n      {nm:\"LiveFlow\",cost:99,nt:\"Google Sheets live\"},\n      {nm:\"Jirav\",cost:150,nt:\"full FP&A platform\"},\n      {nm:\"Clockwork\",cost:99,nt:\"cash-flow forecasting\"},\n      {nm:\"FinOptimal\",cost:150,nt:\"automation + FP&A · est.\"},\n    ]},\n    { key:\"ai\", title:\"AI Layer\", sub:\"(optional, new)\", ai:true, opts:[\n      {nm:\"Intuit Assist\",cost:0,nt:\"included w/ QBO\"},\n      {nm:\"Xero JAX\",cost:0,nt:\"included w/ Xero\"},\n      {nm:\"Booke AI\",cost:129,nt:\"AI bookkeeper add-on\"},\n      {nm:\"Docyt\",cost:299,nt:\"full-service AI · est.\"},\n      {nm:\"None / manual\",cost:0,nt:\"human review only\"},\n    ]},\n  ];\n\n  const sel = {}; CATS.forEach(c=>sel[c.key]={nm:null,cost:0});\n\n  // ---- render ----\n  const catsEl = document.getElementById(\"cats\");\n  CATS.forEach(c=>{\n    const wrap=document.createElement(\"div\"); wrap.className=\"cat\";\n    wrap.innerHTML=`<div class=\"cat-head\">\n        <span class=\"cat-title\">${c.title} ${c.sub?`<span class=\"sub\">${c.sub}</span>`:\"\"}</span>\n        <span class=\"badge\" id=\"badge-${c.key}\">Not selected</span>\n      </div><div class=\"opts\" id=\"opts-${c.key}\"></div>`;\n    catsEl.appendChild(wrap);\n    const optsEl=wrap.querySelector(`#opts-${c.key}`);\n    c.opts.forEach(o=>{\n      const d=document.createElement(\"div\");\n      d.className=\"opt\"+(c.ai?\" ai\":\"\");\n      d.innerHTML=`<div class=\"nm\">${o.nm}</div><div class=\"pr\">${o.cost>0?\"$\"+o.cost+\"/mo\":(o.nm.includes(\"None\")?\"$0\":\"Included\")}</div><div class=\"nt\">${o.nt}</div>`;\n      d.onclick=()=>pick(c.key,o.nm,o.cost,d,optsEl);\n      optsEl.appendChild(d);\n    });\n  });\n\n  function pick(key,nm,cost,el,optsEl){\n    optsEl.querySelectorAll(\".opt\").forEach(x=>x.classList.remove(\"sel\"));\n    el.classList.add(\"sel\");\n    sel[key]={nm,cost};\n    const b=document.getElementById(\"badge-\"+key);\n    b.textContent = cost>0 ? \"$\"+cost+\"/mo\" : (nm.includes(\"None\")?\"None\":\"Included\");\n    b.classList.add(\"set\");\n    update();\n  }\n\n  const SUM=[[\"gl\",\"General Ledger\"],[\"inventory\",\"Inventory\"],[\"payroll\",\"Payroll\"],[\"time\",\"Time Tracking\"],[\"expenses\",\"Expenses\"],[\"reporting\",\"Reporting\"],[\"ai\",\"AI Layer\"]];\n  const sr=document.getElementById(\"summaryRows\");\n  SUM.forEach(([k,label])=>{\n    const r=document.createElement(\"div\"); r.className=\"srow\";\n    r.innerHTML=`<span>${label}</span><span class=\"v empty\" id=\"sv-${k}\">—</span>`;\n    sr.appendChild(r);\n  });\n\n  function update(){\n    let total=0;\n    SUM.forEach(([k])=>{\n      const v=document.getElementById(\"sv-\"+k); const s=sel[k];\n      if(s.nm){ v.textContent=\"$\"+s.cost; v.classList.remove(\"empty\"); }\n      else { v.textContent=\"—\"; v.classList.add(\"empty\"); }\n      total+=s.cost;\n    });\n    document.getElementById(\"totMonthly\").textContent=\"$\"+total.toLocaleString();\n    document.getElementById(\"totAnnual\").textContent=\"$\"+(total*12).toLocaleString();\n    const pct=Math.min(total/1800*100,100);\n    const fill=document.getElementById(\"fill\"); fill.style.width=pct+\"%\";\n    fill.textContent= total>0 ? \"$\"+total.toLocaleString() : \"\";\n    insight(total);\n  }\n\n  function insight(total){\n    const t=[];\n    if(sel.payroll.nm && sel.payroll.nm.startsWith(\"Gusto\") && sel.expenses.nm && sel.expenses.nm!==\"Gusto Expenses\")\n      t.push(\"💡 Gusto includes expense capture — you may not need a separate expenses app.\");\n    if(sel.gl.nm && sel.gl.nm.startsWith(\"QBO\") && sel.time.nm===\"QuickBooks Time\")\n      t.push(\"✅ QuickBooks Time is native to QBO — clean integration, but priced per user (watch the 30-seat cost).\");\n    if(sel.gl.nm && sel.gl.nm.startsWith(\"Xero\") && sel.payroll.nm && sel.payroll.nm.startsWith(\"Gusto\"))\n      t.push(\"✅ Gusto syncs natively to Xero — no manual journal entries.\");\n    if(sel.gl.nm===\"Sage Intacct\" && sel.inventory.nm)\n      t.push(\"💡 Sage Intacct has inventory built in — a separate inventory app may be redundant.\");\n    if(sel.ai.nm && (sel.ai.nm===\"Intuit Assist\"||sel.ai.nm===\"Xero JAX\"))\n      t.push(\"✅ Embedded AI adds no line-item cost — but still run it through the Exercise 2 governance scorecard before client data.\");\n    if(sel.ai.nm && sel.ai.cost>0)\n      t.push(\"🤖 Paid AI layer added — would the hours saved cover it? That's the ROI conversation to have with the client.\");\n    if(total>1400) t.push(\"⚠️ Above the $1,000–$1,400 sweet spot. Check for bundled/overlapping features.\");\n    else if(total>0 && total<1000) t.push(\"🎯 Lean stack. Confirm it still covers inventory + reporting for a 30-person distributor.\");\n    if(!t.length) t.push(\"Select apps to see integration tips and cost-saving opportunities.\");\n    document.getElementById(\"insight\").innerHTML=t.join(\"<br><br>\");\n  }\n\n  function clearAll(){\n    CATS.forEach(c=>{ sel[c.key]={nm:null,cost:0};\n      const b=document.getElementById(\"badge-\"+c.key); b.textContent=\"Not selected\"; b.classList.remove(\"set\");\n    });\n    document.querySelectorAll(\".opt\").forEach(o=>o.classList.remove(\"sel\"));\n    update();\n  }\n\n  // ---- timer ----\n  let ti=null;\n  function startTimer(){\n    if(ti) clearInterval(ti);\n    let left=720; const d=document.getElementById(\"timer\");\n    ti=setInterval(()=>{\n      left--; const m=Math.floor(left/60), s=left%60;\n      d.textContent=m+\":\"+String(s).padStart(2,\"0\");\n      if(left<=60) d.style.color=\"#B91C1C\";\n      if(left<=0){ clearInterval(ti); d.textContent=\"TIME!\"; }\n    },1000);\n  }\n  update();\n</script>\n</body>\n</html>\n"
  }
}