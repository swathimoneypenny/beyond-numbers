# Base URL of the FastAPI auth backend (no trailing slash).
# The client appends /api/auth/... to this value.
#
# Local development against a backend running on your machine:
#   VITE_API_URL=http://127.0.0.1:8000
# Production:
#   VITE_API_URL=https://beyond-numbers.com
#
# Copy this file to .env.local to override the checked-in defaults in
# .env.development / .env.production without changing them.
VITE_API_URL=http://127.0.0.1:8000
