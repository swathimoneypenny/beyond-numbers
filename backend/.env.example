# Beyond Numbers auth backend — example environment.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
#   PowerShell:  Copy-Item .env.example .env

# --- Security ------------------------------------------------------------
# REQUIRED in production. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# If left blank, the app generates a random key at startup (dev only — every
# restart invalidates all issued tokens).
JWT_SECRET=

# HS256 is fine for a single-service setup.
JWT_ALGORITHM=HS256

# Access token lifetime, in minutes. 60 * 24 = 1 day.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ------------------------------------------------------------
# SQLite by default; the file is created next to the backend on first run.
# Swap for postgresql+psycopg://user:pass@host/db later without code changes.
DATABASE_URL=sqlite:///./beyond_numbers.db

# --- CORS ----------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,https://beyond-numbers.com,https://www.beyond-numbers.com

# --- App -----------------------------------------------------------------
# "development" enables /docs and a permissive startup. Use "production" on EC2.
ENVIRONMENT=development

# Base URL of the frontend — used to build the password-reset link
# (<FRONTEND_BASE_URL>/reset-password?token=...).
FRONTEND_BASE_URL=https://beyond-numbers.com

# --- Email / AWS SES -----------------------------------------------------
# Region where SES is set up and the domain is verified.
AWS_REGION=ap-southeast-2
# Verified sender address for the reset email.
SES_SENDER=noreply@beyond-numbers.com
#
# AWS credentials are NOT set here. On EC2, attach an IAM role granting
# ses:SendEmail (boto3 picks it up automatically). Only if you can't use a role,
# set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY in the environment instead.

# --- Password reset ------------------------------------------------------
# Reset-link lifetime (minutes) and the /forgot-password abuse guard.
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
FORGOT_PASSWORD_MAX_PER_WINDOW=5
FORGOT_PASSWORD_WINDOW_SECONDS=900
